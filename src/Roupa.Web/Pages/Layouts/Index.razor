@page "/layouts"
@attribute [Authorize]
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Layouts</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Fichas de Layout</h2>
    <button class="btn btn-primary" @onclick="() => mostrarForm = true">+ Novo Layout</button>
</div>

@if (mostrarForm)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold">Nova Ficha de Layout</div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(erroForm))
            {
                <div class="alert alert-danger">@erroForm</div>
            }
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Cliente *</label>
                    <select class="form-select" @bind="novoLayout.ClienteId">
                        <option value="">Selecione...</option>
                        @foreach (var c in clientes)
                        {
                            <option value="@c.Id">@c.NomeFantasia</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Modelo *</label>
                    <input class="form-control" @bind="novoLayout.Modelo" placeholder="Ex: Camisa polo MC" />
                </div>
                <div class="col-12">
                    <label class="form-label">Descrição *</label>
                    <textarea class="form-control" rows="2" @bind="novoLayout.Descricao"
                        placeholder="Ex: Camisa polo MC, sem bolso, pé de gola na cor BRANCO."></textarea>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Tipo de Produto *</label>
                    <select class="form-select" @bind="novoLayout.TipoProduto">
                        @foreach (var tp in Enum.GetValues<Models.TipoProduto>())
                        {
                            <option value="@tp">@tp</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Tecido *</label>
                    <input class="form-control" @bind="novoLayout.Tecido"
                        placeholder="Ex: Malha piquet PV na cor 700 Vermelho" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Cores *</label>
                    <input class="form-control" @bind="novoLayout.Cores" placeholder="Ex: Vermelho e Branco" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Tipo Logomarca *</label>
                    <select class="form-select" @bind="novoLayout.TipoLogomarca">
                        @foreach (var tl in Enum.GetValues<Models.TipoLogomarca>())
                        {
                            <option value="@tl">@tl</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Posição *</label>
                    <input class="form-control" @bind="novoLayout.PosicaoLogomarca"
                        placeholder="Ex: Frente esquerda" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Tamanho *</label>
                    <input class="form-control" @bind="novoLayout.TamanhoLogomarca" placeholder="Ex: 7cm" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Cor Logomarca *</label>
                    <input class="form-control" @bind="novoLayout.CorLogomarca" placeholder="Ex: Branco" />
                </div>
                <div class="col-12">
                    <label class="form-label">Outros</label>
                    <input class="form-control" @bind="novoLayout.Outros"
                        placeholder="Ex: Etiqueta da bandeira da Itália na manga direita." />
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" @onclick="SalvarLayout" disabled="@salvando">
                    @if (salvando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Salvar
                </button>
                <button class="btn btn-outline-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    </div>
}

@if (carregando)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (!layouts.Any())
{
    <div class="text-center py-5 text-muted">Nenhum layout cadastrado.</div>
}
else
{
    <div class="row g-3">
        @foreach (var l in layouts)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-dark text-white d-flex justify-content-between">
                        <span class="fw-semibold">@l.Modelo</span>
                        <span class="badge bg-secondary">@l.TipoProduto</span>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-2">@l.NomeCliente</p>
                        <p class="mb-1 small"><strong>Tecido:</strong> @l.Tecido</p>
                        <p class="mb-1 small"><strong>Cores:</strong> @l.Cores</p>
                        <p class="mb-1 small"><strong>Logomarca:</strong> @l.TipoLogomarca — @l.PosicaoLogomarca (@l.TamanhoLogomarca) @l.CorLogomarca</p>
                        @if (!string.IsNullOrEmpty(l.Outros))
                        {
                            <p class="mb-0 small text-muted"><strong>Outros:</strong> @l.Outros</p>
                        }
                    </div>
                    <div class="card-footer bg-white border-0">
                        <small class="text-muted">Criado em @l.CriadoEm.ToString("dd/MM/yyyy")</small>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [SupplyParameterFromQuery] public string? ClienteId { get; set; }

    private List<Models.LayoutDto> layouts = [];
    private List<Models.ClienteDto> clientes = [];
    private Models.CriarLayoutModel novoLayout = new();
    private bool carregando = true, mostrarForm, salvando;
    private string erroForm = "";

    protected override async Task OnInitializedAsync()
    {
        clientes = await Api.ListarClientesAsync();
        if (Guid.TryParse(ClienteId, out var cId))
        {
            layouts = await Api.ListarLayoutsPorClienteAsync(cId);
            novoLayout.ClienteId = cId;
        }
        else layouts = await Api.ListarLayoutsAsync();
        carregando = false;
    }

    private void Cancelar() { mostrarForm = false; erroForm = ""; }

    private async Task SalvarLayout()
    {
        salvando = true;
        erroForm = "";
        var (sucesso, _, erro) = await Api.CriarLayoutAsync(novoLayout);
        if (sucesso)
        {
            mostrarForm = false;
            novoLayout = new();
            layouts = await Api.ListarLayoutsAsync();
        }
        else erroForm = erro ?? "Erro ao salvar.";
        salvando = false;
    }
}
