@page "/layouts"
@attribute [Authorize]
@inject ApiService Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Fichas de Layout</PageTitle>

<!-- ═══════════════════════════════════════════
     HEADER
═══════════════════════════════════════════ -->
<div class="page-header">
    <div>
        <div class="page-title">Fichas de Layout</div>
        <div class="page-subtitle">Cada ficha aprovada é a ordem de produção da fábrica</div>
    </div>
    <button class="btn-primary-modern" @onclick="AbrirDrawer">
        <i class="bi bi-plus-lg"></i> Nova Ficha
    </button>
</div>

<!-- ═══════════════════════════════════════════
     DRAWER — NOVA FICHA
═══════════════════════════════════════════ -->
@if (mostrarDrawer)
{
    <div class="drawer-overlay" @onclick="FecharDrawer"></div>
    <div class="drawer" style="width:560px">
        <div class="drawer-header">
            <span class="drawer-title"><i class="bi bi-palette2 me-2 text-primary"></i>Nova Ficha de Layout</span>
            <button class="drawer-close" @onclick="FecharDrawer"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="drawer-body form-modern">
            @if (!string.IsNullOrEmpty(erroForm))
            {
                <div class="form-error-banner"><i class="bi bi-exclamation-circle-fill"></i> @erroForm</div>
            }

            <div class="section-divider">Identificação</div>
            <div class="row g-3">
                <div class="col-12">
                    <div class="form-group">
                        <label>Cliente *</label>
                        <select class="input-field @(invalidos.Contains("cliente") ? "invalido" : "")"
                                @bind="novoLayout.ClienteId" style="appearance:auto">
                            <option value="">Selecione o cliente...</option>
                            @foreach (var c in clientes)
                            {
                                <option value="@c.Id">@c.NomeFantasia</option>
                            }
                        </select>
                        @if (invalidos.Contains("cliente")) { <span class="campo-erro">Selecione um cliente</span> }
                    </div>
                </div>
                <div class="col-7">
                    <div class="form-group">
                        <label>Nome do Modelo *</label>
                        <input class="input-field @(invalidos.Contains("modelo") ? "invalido" : "")"
                               @bind="novoLayout.Modelo" placeholder="Ex: Polo MC Sem Bolso" />
                        @if (invalidos.Contains("modelo")) { <span class="campo-erro">Informe o modelo</span> }
                    </div>
                </div>
                <div class="col-5">
                    <div class="form-group">
                        <label>Tipo de Produto *</label>
                        <select class="input-field" @bind="novoLayout.TipoProduto" style="appearance:auto">
                            @foreach (var tp in Enum.GetValues<Models.TipoProduto>())
                            {
                                <option value="@tp">@NomeTipo(tp)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-12">
                    <div class="form-group">
                        <label>Descrição completa *</label>
                        <textarea class="input-field @(invalidos.Contains("desc") ? "invalido" : "")"
                                  rows="2" @bind="novoLayout.Descricao"
                                  placeholder="Ex: Camisa polo MC, sem bolso, pé de gola na cor BRANCO, colarinho 2 botões."></textarea>
                        @if (invalidos.Contains("desc")) { <span class="campo-erro">Descreva o produto</span> }
                    </div>
                </div>
            </div>

            <div class="section-divider">Tecido & Cores</div>
            <div class="form-group">
                <label>Tecido *</label>
                <input class="input-field @(invalidos.Contains("tecido") ? "invalido" : "")"
                       @bind="novoLayout.Tecido" placeholder="Ex: Malha piquet PV 700" />
                @if (invalidos.Contains("tecido")) { <span class="campo-erro">Informe o tecido</span> }
            </div>
            <div class="form-group">
                <label>Cores * <span style="font-weight:400;color:var(--surface-400)">(selecione até 3)</span></label>
                <div class="cor-swatches @(invalidos.Contains("cores") ? "invalido" : "")">
                    @foreach (var cor in TodasCores)
                    {
                        var sel = coresSel.Contains(cor.Nome);
                        <button type="button"
                                class="cor-swatch @(sel ? "selected" : "")"
                                style="background:@cor.Hex;color:@cor.Fg;border-color:@(sel ? cor.Hex : "transparent")"
                                title="@cor.Nome"
                                @onclick="() => ToggleCor(cor.Nome)">
                            @if (sel) { <i class="bi bi-check-lg"></i> }
                        </button>
                    }
                </div>
                @if (coresSel.Any())
                {
                    <div class="cor-tags">
                        @foreach (var c in coresSel)
                        {
                            var hex = TodasCores.FirstOrDefault(x => x.Nome == c)?.Hex ?? "#888";
                            <span class="cor-tag">
                                <span style="background:@hex;width:10px;height:10px;border-radius:50%;display:inline-block;margin-right:.25rem;border:1px solid rgba(0,0,0,.15)"></span>
                                @c
                                <button type="button" @onclick="() => coresSel.Remove(c)">×</button>
                            </span>
                        }
                    </div>
                }
                @if (invalidos.Contains("cores")) { <span class="campo-erro">Selecione ao menos uma cor</span> }
            </div>

            <div class="section-divider">Logomarca / Aplicação</div>
            <div class="row g-3">
                <div class="col-4">
                    <div class="form-group">
                        <label>Tipo de Aplicação *</label>
                        <select class="input-field" @bind="novoLayout.TipoLogomarca" style="appearance:auto">
                            @foreach (var tl in Enum.GetValues<Models.TipoLogomarca>())
                            {
                                <option value="@tl">@NomeLogomarca(tl)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-4">
                    <div class="form-group">
                        <label>Posição *</label>
                        <input class="input-field @(invalidos.Contains("posicao") ? "invalido" : "")"
                               @bind="novoLayout.PosicaoLogomarca" placeholder="Frente esquerda" />
                        @if (invalidos.Contains("posicao")) { <span class="campo-erro">Informe a posição</span> }
                    </div>
                </div>
                <div class="col-2">
                    <div class="form-group">
                        <label>Tamanho</label>
                        <input class="input-field" @bind="novoLayout.TamanhoLogomarca" placeholder="7cm" />
                    </div>
                </div>
                <div class="col-2">
                    <div class="form-group">
                        <label>Cor logo</label>
                        <input class="input-field" @bind="novoLayout.CorLogomarca" placeholder="Branco" />
                    </div>
                </div>
            </div>

            <div class="section-divider">Medidas de Referência</div>
            <div class="row g-2">
                @foreach (var tam in tamanhos)
                {
                    <div class="col-4">
                        <div class="form-group">
                            <label style="font-size:.75rem">@tam</label>
                            <input class="input-field" style="font-size:.85rem"
                                   value="@(medidas.GetValueOrDefault(tam, ""))"
                                   @oninput="@(e => medidas[tam] = e.Value?.ToString() ?? "")"
                                   placeholder="P x L cm" />
                        </div>
                    </div>
                }
            </div>

            <div class="section-divider">Observações</div>
            <div class="form-group">
                <textarea class="input-field" rows="2" @bind="novoLayout.Outros"
                          placeholder="Ex: Etiqueta bandeira Itália manga direita. Gola em contraste."></textarea>
            </div>
        </div>
        <div class="drawer-footer">
            <button class="btn-ghost" @onclick="FecharDrawer">Cancelar</button>
            <button class="btn-primary-modern" @onclick="SalvarLayout" disabled="@salvando">
                @if (salvando)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                    <span>Gerando avatar...</span>
                }
                else
                {
                    <i class="bi bi-magic"></i>
                    <span>Salvar & Gerar Avatar</span>
                }
            </button>
        </div>
    </div>
}

<!-- CONFIRM EXCLUIR FICHA -->
@if (confirmExcluir is not null)
{
    <div class="drawer-overlay" @onclick="() => confirmExcluir = null"></div>
    <div class="confirm-modal">
        <div class="confirm-icon danger"><i class="bi bi-trash"></i></div>
        <div class="confirm-title">Excluir ficha?</div>
        <div class="confirm-msg">A ficha "@confirmExcluir.Modelo" será removida permanentemente. Esta ação não pode ser desfeita.</div>
        <div class="confirm-btns">
            <button class="btn-ghost" @onclick="() => confirmExcluir = null">Cancelar</button>
            <button class="btn-danger-modern" @onclick="ExcluirFicha" disabled="@salvando">
                @if (salvando) { <span class="spinner-border spinner-border-sm"></span> }
                else { <i class="bi bi-trash"></i> }
                Excluir
            </button>
        </div>
    </div>
}

<!-- ═══════════════════════════════════════════
     GALERIA
═══════════════════════════════════════════ -->
@if (carregando)
{
    <div class="loading-center"><div class="spinner-border text-primary"></div></div>
}
else if (!layouts.Any())
{
    <div class="card-modern">
        <div class="empty-state">
            <i class="bi bi-palette2"></i>
            <p>Nenhuma ficha criada ainda.</p>
            <button class="btn-primary-modern mt-3" @onclick="AbrirDrawer">
                <i class="bi bi-magic"></i> Criar primeira ficha
            </button>
        </div>
    </div>
}
else
{
    <div class="gallery-grid">
        @foreach (var l in layouts)
        {
            <div class="gallery-card @(l.Aprovado ? "aprovado" : "")">
                <div class="gallery-avatar">
                    <img src="@UrlAvatarFrent(l)" alt="@l.Modelo"
                         loading="lazy" onerror="this.src='/img/placeholder.svg'" />
                    @if (l.Aprovado)
                    {
                        <div class="gallery-badge-aprovado">
                            <i class="bi bi-check-circle-fill"></i> Aprovado
                        </div>
                    }
                    <button class="gallery-del-btn" title="Excluir ficha"
                            @onclick="() => confirmExcluir = l">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
                <div class="gallery-info">
                    <div class="gallery-modelo">@l.Modelo</div>
                    <div class="gallery-cliente">@l.NomeCliente</div>
                    <div class="gallery-tags">
                        <span class="badge-modern draft" style="font-size:.68rem">@NomeTipo(l.TipoProduto)</span>
                        <span class="badge-modern info" style="font-size:.68rem">@NomeLogomarca(l.TipoLogomarca)</span>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [SupplyParameterFromQuery] public string? ClienteId { get; set; }

    record CorDef(string Nome, string Hex, string Fg);

    static readonly CorDef[] TodasCores =
    [
        new("Branco",        "#FFFFFF", "#111111"),
        new("Preto",         "#111111", "#FFFFFF"),
        new("Cinza Claro",   "#D1D5DB", "#111111"),
        new("Cinza Médio",   "#6B7280", "#FFFFFF"),
        new("Azul Marinho",  "#1E3A5F", "#FFFFFF"),
        new("Azul Royal",    "#1D4ED8", "#FFFFFF"),
        new("Azul Claro",    "#3B82F6", "#FFFFFF"),
        new("Vermelho",      "#DC2626", "#FFFFFF"),
        new("Vinho/Bordô",   "#7F1D1D", "#FFFFFF"),
        new("Rosa",          "#F9A8D4", "#111111"),
        new("Verde",         "#16A34A", "#FFFFFF"),
        new("Verde Militar", "#365314", "#FFFFFF"),
        new("Amarelo",       "#EAB308", "#111111"),
        new("Laranja",       "#EA580C", "#FFFFFF"),
        new("Roxo",          "#7C3AED", "#FFFFFF"),
        new("Lilás",         "#C4B5FD", "#111111"),
        new("Bege/Cru",      "#D4A574", "#111111"),
        new("Marrom",        "#92400E", "#FFFFFF"),
    ];

    private List<Models.LayoutDto>  layouts    = [];
    private List<Models.ClienteDto> clientes   = [];
    private Models.CriarLayoutModel novoLayout = new();
    private HashSet<string>         invalidos  = [];
    private HashSet<string>         coresSel   = [];
    private Dictionary<string, string> medidas = [];
    private bool carregando = true, mostrarDrawer, salvando;
    private string erroForm = "";

    // Exclusão
    private Models.LayoutDto? confirmExcluir;

    private static readonly string[] tamanhos = ["PP","P","M","G","GG","EG","EGG","Personalizado"];

    protected override async Task OnInitializedAsync()
    {
        clientes = await Api.ListarClientesAsync();
        await CarregarLayouts();
        carregando = false;
    }

    private async Task CarregarLayouts()
    {
        if (Guid.TryParse(ClienteId, out var cId))
        {
            layouts = await Api.ListarLayoutsPorClienteAsync(cId);
            novoLayout.ClienteId = cId;
        }
        else layouts = await Api.ListarLayoutsAsync();
    }

    private void AbrirDrawer()
    {
        mostrarDrawer = true; erroForm = ""; invalidos.Clear();
        medidas = tamanhos.ToDictionary(t => t, _ => "");
        coresSel.Clear();
        novoLayout = new();
        if (Guid.TryParse(ClienteId, out var cId)) novoLayout.ClienteId = cId;
    }

    private void ToggleCor(string nome)
    {
        if (coresSel.Contains(nome))
            coresSel.Remove(nome);
        else if (coresSel.Count < 3)
            coresSel.Add(nome);
    }

    private void FecharDrawer() { mostrarDrawer = false; erroForm = ""; invalidos.Clear(); }


    private async Task SalvarLayout()
    {
        invalidos.Clear();
        if (novoLayout.ClienteId == default)   invalidos.Add("cliente");
        if (string.IsNullOrWhiteSpace(novoLayout.Modelo))     invalidos.Add("modelo");
        if (string.IsNullOrWhiteSpace(novoLayout.Descricao))  invalidos.Add("desc");
        if (string.IsNullOrWhiteSpace(novoLayout.Tecido))     invalidos.Add("tecido");
        if (!coresSel.Any())                                   invalidos.Add("cores");
        if (string.IsNullOrWhiteSpace(novoLayout.PosicaoLogomarca)) invalidos.Add("posicao");
        if (invalidos.Any()) return;

        novoLayout.Cores = string.Join(" e ", coresSel);

        // Serializa medidas no campo Outros como JSON complementar
        var medidasStr = string.Join(", ", medidas.Where(m => !string.IsNullOrWhiteSpace(m.Value))
                                                   .Select(m => $"{m.Key}: {m.Value}"));
        if (!string.IsNullOrWhiteSpace(medidasStr))
            novoLayout.Outros = (novoLayout.Outros?.Trim() + "\n\nGrade: " + medidasStr).Trim();

        salvando = true;
        erroForm = "";
        var (sucesso, _, erro) = await Api.CriarLayoutAsync(novoLayout);
        if (sucesso)
        {
            FecharDrawer();
            await CarregarLayouts();
        }
        else erroForm = erro ?? "Erro ao salvar.";
        salvando = false;
    }

    private async Task ExcluirFicha()
    {
        if (confirmExcluir is null) return;
        salvando = true;
        var (ok, _) = await Api.ExcluirLayoutAsync(confirmExcluir.Id);
        if (ok) { confirmExcluir = null; await CarregarLayouts(); }
        salvando = false;
    }

    // ── Geração das URLs de avatar via Pollinations.ai (free, sem API key) ──
    private string UrlAvatarFrent(Models.LayoutDto l) => BuildAvatarUrl(l, "front view");

    private static string BuildAvatarUrl(Models.LayoutDto l, string view)
    {
        var tipo  = NomeTipoEn(l.TipoProduto);
        var cores = l.Cores.ToLowerInvariant();
        var logo  = $"{NomeLogomarcaEn(l.TipoLogomarca)} logo on {l.PosicaoLogomarca}";
        var prompt = $"professional fashion mannequin wearing {tipo}, {cores} color, " +
                     $"{l.Tecido} fabric, {logo}, {view}, " +
                     $"clean white studio background, full body, product photography, high quality, 8k";
        var seed = (l.Id.GetHashCode() + view.GetHashCode()) & 0x7FFFFFFF;
        return $"https://image.pollinations.ai/prompt/{Uri.EscapeDataString(prompt)}" +
               $"?width=420&height=600&model=flux&seed={seed}&nologo=true";
    }

    // ── Helpers de exibição ──
    private static string NomeTipo(Models.TipoProduto t) => t switch
    {
        Models.TipoProduto.CamisaPolo   => "Camisa Polo",
        Models.TipoProduto.CamisaMalha  => "Camiseta Malha",
        Models.TipoProduto.Jaleco       => "Jaleco",
        _ => t.ToString()
    };

    private static string NomeTipoEn(Models.TipoProduto t) => t switch
    {
        Models.TipoProduto.CamisaPolo  => "polo shirt",
        Models.TipoProduto.CamisaMalha => "t-shirt",
        Models.TipoProduto.Jaleco      => "work jacket",
        _ => t.ToString().ToLower()
    };

    private static string NomeLogomarca(Models.TipoLogomarca t) => t switch
    {
        Models.TipoLogomarca.Bordado    => "Bordado",
        Models.TipoLogomarca.SilkScreen => "Silk Screen",
        Models.TipoLogomarca.Sublimacao => "Sublimação",
        Models.TipoLogomarca.Transfer   => "Transfer",
        _ => t.ToString()
    };

    private static string NomeLogomarcaEn(Models.TipoLogomarca t) => t switch
    {
        Models.TipoLogomarca.Bordado    => "embroidered",
        Models.TipoLogomarca.SilkScreen => "silk screen printed",
        Models.TipoLogomarca.Sublimacao => "sublimation printed",
        Models.TipoLogomarca.Transfer   => "heat transfer",
        _ => t.ToString().ToLower()
    };
}
