@page "/studio"
@attribute [Authorize]
@inject ApiService Api
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Studio — Provador Virtual</PageTitle>

<div class="studio-root">

    <!-- TOP BAR -->
    <div class="studio-topbar">
        <div class="studio-brand">
            <i class="bi bi-controller"></i> Studio
            <span class="studio-brand-sub">Provador Virtual</span>
        </div>

        @if (etapa != Etapa.Avatares)
        {
            <div class="studio-breadcrumb">
                <span style="cursor:pointer;color:rgba(255,255,255,.4)" @onclick="VoltarAvatares">
                    <i class="bi bi-person-circle"></i> @avatarAtual!.Nome
                </span>
                @if (etapa == Etapa.Resultado)
                {
                    <i class="bi bi-chevron-right" style="color:rgba(255,255,255,.2)"></i>
                    <span style="color:#a78bfa;font-weight:600">
                        <i class="bi bi-shirt-fill"></i> @fichaAtual!.Modelo
                    </span>
                }
            </div>
        }

        <div style="flex:1"></div>

        @if (etapa != Etapa.Avatares)
        {
            <button class="studio-nav-btn" @onclick="VoltarAvatares">
                <i class="bi bi-arrow-left"></i> Trocar personagem
            </button>
        }
        <button class="studio-sair" @onclick='() => Nav.NavigateTo("/layouts")'>
            <i class="bi bi-x-lg"></i> Sair
        </button>
    </div>

    <!-- ══ ETAPA 1 — TV MODE: avatares passando ══ -->
    @if (etapa == Etapa.Avatares)
    {
        <div class="studio-tv">
            <!-- Avatar em destaque (TV) -->
            <div class="studio-tv-stage" @onclick="() => EscolherAvatar(Avatares[tvIndex])">
                <img src="@AvatarUrl(Avatares[tvIndex])"
                     alt="@Avatares[tvIndex].Nome"
                     class="studio-tv-img @(tvTransition ? "fade" : "")"
                     onerror="this.src='/img/placeholder.svg'" />

                <div class="studio-tv-info">
                    <div class="studio-tv-nome">@Avatares[tvIndex].Nome</div>
                    <div class="studio-tv-tipo">@Avatares[tvIndex].Descricao</div>
                    <div class="studio-tv-cta">
                        <i class="bi bi-bag-fill"></i> Clique para experimentar roupas
                    </div>
                </div>

                <!-- Botão pausar/retomar -->
                <button class="studio-tv-pause" @onclick:stopPropagation="true"
                        @onclick="TogglePause" title="@(pausado ? "Retomar" : "Pausar")">
                    <i class="bi @(pausado ? "bi-play-fill" : "bi-pause-fill")"></i>
                </button>
            </div>

            <!-- Miniaturas dos 4 avatares -->
            <div class="studio-tv-thumbs">
                @for (int i = 0; i < Avatares.Length; i++)
                {
                    var idx = i;
                    var av  = Avatares[idx];
                    <div class="studio-tv-thumb @(tvIndex == idx ? "ativo" : "")"
                         @onclick="() => SelecionarThumb(idx)">
                        <img src="@AvatarThumbUrl(av)" alt="@av.Nome"
                             onerror="this.src='/img/placeholder.svg'" loading="lazy" />
                        <span>@av.Nome</span>
                    </div>
                }
            </div>

            <!-- Dots indicador -->
            <div class="studio-tv-dots">
                @for (int i = 0; i < Avatares.Length; i++)
                {
                    var idx = i;
                    <span class="studio-tv-dot @(tvIndex == idx ? "ativo" : "")"
                          @onclick="() => SelecionarThumb(idx)"></span>
                }
            </div>
        </div>
    }

    <!-- ══ ETAPA 2 — GUARDA-ROUPA ══ -->
    @if (etapa == Etapa.GuardaRoupa)
    {
        <div class="studio-guardaroupa">
            <div class="studio-av-lateral">
                <img src="@AvatarUrl(avatarAtual!)" alt="@avatarAtual!.Nome"
                     onerror="this.src='/img/placeholder.svg'" />
                <div class="studio-av-lateral-nome">@avatarAtual.Nome</div>
                <div class="studio-av-lateral-tipo">@avatarAtual.Descricao</div>
            </div>

            <div class="studio-roupas">
                <div class="studio-roupas-title">
                    <i class="bi bi-bag-fill"></i>
                    O que @avatarAtual!.Nome vai experimentar?
                </div>

                @if (carregando)
                {
                    <div class="studio-loading-msg">
                        <div class="studio-gerando-spinner"></div> Carregando roupas...
                    </div>
                }
                else if (!fichas.Any())
                {
                    <div class="studio-sem-roupas">
                        <i class="bi bi-bag-x"></i>
                        <p>Nenhuma peça cadastrada.</p>
                        <a href="/layouts" class="btn-primary-modern">
                            <i class="bi bi-plus-lg"></i> Cadastrar peças
                        </a>
                    </div>
                }
                else
                {
                    <div class="studio-roupas-grid">
                        @foreach (var f in fichas)
                        {
                            <div class="studio-roupa-card" @onclick="() => EscolherRoupa(f)">
                                <div class="studio-roupa-img">
                                    <img src="@FlatLayUrl(f)" alt="@f.Modelo"
                                         onerror="this.src='/img/placeholder.svg'" loading="lazy" />
                                    <div class="studio-roupa-overlay">
                                        <i class="bi bi-magic"></i> Experimentar
                                    </div>
                                </div>
                                <div class="studio-roupa-info">
                                    <div class="studio-roupa-nome">@f.Modelo</div>
                                    <div class="studio-roupa-tipo">@NomeTipo(f.TipoProduto)</div>
                                    <div class="studio-roupa-cores">
                                        @foreach (var hex in CoresHex(f.Cores).Take(4))
                                        {
                                            <span class="studio-cor-bolinha" style="background:@hex"
                                                  title="@f.Cores"></span>
                                        }
                                        <span class="studio-roupa-cor-nome">@f.Cores</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    <!-- ══ ETAPA 3 — RESULTADO ══ -->
    @if (etapa == Etapa.Resultado)
    {
        <div class="studio-resultado">
            <div class="studio-resultado-foto">
                @if (gerando)
                {
                    <div class="studio-gerando-overlay">
                        <div class="studio-gerando-spinner"></div>
                        <div class="studio-gerando-txt">
                            <strong>Gerando visualização...</strong><br />
                            <span>@fichaAtual!.Cores — @fichaAtual.Modelo</span>
                        </div>
                    </div>
                }
                <img src="@imgResultado"
                     alt="@avatarAtual!.Nome vestindo @fichaAtual!.Modelo"
                     class="@(gerando ? "blur" : "")"
                     onerror="this.src='/img/placeholder.svg'" />
                @if (!gerando)
                {
                    <div class="studio-resultado-label">
                        @avatarAtual!.Nome — @fichaAtual!.Modelo (@fichaAtual.Cores)
                    </div>
                }
            </div>

            <div class="studio-resultado-info">
                <div class="studio-res-titulo">@fichaAtual!.Modelo</div>
                <div class="studio-res-linha"><b>Personagem:</b> @avatarAtual!.Nome</div>
                <div class="studio-res-linha"><b>Tipo:</b> @NomeTipo(fichaAtual.TipoProduto)</div>
                <div class="studio-res-linha"><b>Tecido:</b> @fichaAtual.Tecido</div>
                <div class="studio-res-linha">
                    <b>Cores:</b>
                    @foreach (var hex in CoresHex(fichaAtual.Cores))
                    {
                        <span class="studio-cor-bolinha lg" style="background:@hex;margin-left:.3rem"></span>
                    }
                    <span style="margin-left:.35rem">@fichaAtual.Cores</span>
                </div>
                <div class="studio-res-linha">
                    <b>Logomarca:</b> @NomeLogomarca(fichaAtual.TipoLogomarca) — @fichaAtual.PosicaoLogomarca
                </div>

                <div class="studio-resultado-btns">
                    <a class="studio-btn-download"
                       href="@imgResultado"
                       download="@($"{avatarAtual!.Nome}_{fichaAtual!.Modelo}.jpg")"
                       target="_blank">
                        <i class="bi bi-download"></i> Baixar Foto
                    </a>
                    <button class="studio-btn-pdf" @onclick="ImprimirProposta">
                        <i class="bi bi-file-earmark-pdf-fill"></i> Proposta PDF
                    </button>
                    <button class="studio-btn-regerar" @onclick="GerarTryOn" disabled="@gerando">
                        <i class="bi bi-arrow-clockwise"></i> Regerar
                    </button>
                    <button class="studio-btn-trocar" @onclick="() => etapa = Etapa.GuardaRoupa">
                        <i class="bi bi-bag-fill"></i> Trocar roupa
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(erroStudio))
                {
                    <div class="studio-erro">@erroStudio</div>
                }
            </div>
        </div>
    }
</div>

<!-- PRINT -->
@if (etapa == Etapa.Resultado && avatarAtual is not null && fichaAtual is not null)
{
    <div class="proposta-print">
        <div class="proposta-header">
            <div class="proposta-logo"><i class="bi bi-scissors"></i> Roupa Solution</div>
            <div class="proposta-titulo">PROPOSTA DE UNIFORME</div>
            <div class="proposta-data">@DateTime.Now.ToString("dd/MM/yyyy")</div>
        </div>
        <div class="proposta-body">
            <img src="@imgResultado" class="proposta-avatar-img" />
            <div class="proposta-detalhes">
                <h2>@fichaAtual.Modelo</h2>
                <p><b>Personagem:</b> @avatarAtual.Nome (@avatarAtual.Descricao)</p>
                <p><b>Tipo:</b> @NomeTipo(fichaAtual.TipoProduto)</p>
                <p><b>Tecido:</b> @fichaAtual.Tecido</p>
                <p><b>Cores:</b> @fichaAtual.Cores</p>
                <p><b>Logomarca:</b> @NomeLogomarca(fichaAtual.TipoLogomarca) — @fichaAtual.PosicaoLogomarca</p>
                @if (!string.IsNullOrWhiteSpace(fichaAtual.Outros))
                {
                    <p><b>Obs:</b> @fichaAtual.Outros</p>
                }
            </div>
        </div>
        <div class="proposta-footer">Roupa Solution — Gestão Têxtil Profissional</div>
    </div>
}

@code {
    enum Etapa { Avatares, GuardaRoupa, Resultado }

    record AvatarDef(string Id, string Nome, string Descricao, string Prompt, int Seed);

    static readonly AvatarDef[] Avatares =
    [
        new("ketlen", "Ketlen", "Modelo Feminina",
            "RAW photo, photorealistic, young Brazilian woman, light tan skin, long dark wavy hair, slim figure, natural makeup, almond eyes, full lips, standing relaxed, full body, white seamless studio background, Canon EOS 5D, 85mm, studio softbox lighting, 8k UHD, sharp focus",
            3001),
        new("jorge", "Jorge", "Modelo Masculino",
            "RAW photo, photorealistic, Black Brazilian man, dark skin, short fade haircut, strong jawline, dark brown eyes, athletic build, standing confident, full body, white seamless studio background, Canon EOS 5D, 85mm, studio softbox lighting, 8k UHD, sharp focus",
            3002),
        new("micaela", "Micaela", "Modelo Feminina Negra",
            "RAW photo, photorealistic, Black Brazilian woman, dark skin, natural tight curly afro hair, warm brown eyes, medium athletic build, warm confident smile, standing, full body, white seamless studio background, Canon EOS 5D, 85mm, studio softbox lighting, 8k UHD, sharp focus",
            3003),
        new("veloso", "Veloso", "Estilo Nerd",
            "RAW photo, photorealistic, young Brazilian man, medium skin tone, round glasses, slightly wavy brown hair, slim build, intelligent friendly expression, casual smart outfit, standing, full body, white seamless studio background, Canon EOS 5D, 50mm, natural studio lighting, 8k UHD, sharp focus",
            3004),
    ];

    static string AvatarUrl(AvatarDef av) =>
        "https://image.pollinations.ai/prompt/" +
        Uri.EscapeDataString(av.Prompt) +
        "?width=480&height=720&model=flux&seed=" + av.Seed + "&nologo=true&enhance=true";

    static string AvatarThumbUrl(AvatarDef av) =>
        "https://image.pollinations.ai/prompt/" +
        Uri.EscapeDataString(av.Prompt) +
        "?width=120&height=180&model=flux&seed=" + av.Seed + "&nologo=true";

    static string FlatLayUrl(Models.LayoutDto f)
    {
        var tipo = NomeTipoEn(f.TipoProduto);
        var cor  = CorIngles(f.Cores);
        var p    = "professional product photography, flat lay fashion " + tipo +
                   ", solid opaque " + cor + " color, " + f.Tecido + " fabric" +
                   ", isolated pure white background, vibrant saturated color, no shadows, 8k";
        return "https://image.pollinations.ai/prompt/" +
               Uri.EscapeDataString(p) +
               "?width=320&height=400&model=flux&seed=" + (f.Id.GetHashCode() & 0x7FFFFFFF) + "&nologo=true";
    }

    static string TryOnUrl(AvatarDef av, Models.LayoutDto f)
    {
        var tipo   = NomeTipoEn(f.TipoProduto);
        var cor    = CorIngles(f.Cores);
        var logo   = NomeLogomarcaEn(f.TipoLogomarca) + " logo on " + f.PosicaoLogomarca;
        var avBase = av.Prompt.Split(',')[0].Replace("RAW photo, photorealistic,", "").Trim();

        var prompt = "RAW photo, photorealistic, " + avBase +
                     " wearing a " + cor + " " + tipo +
                     ", the garment is solid opaque " + cor + " colored, " + f.Tecido + " fabric" +
                     ", with " + logo +
                     ", full body, white seamless studio background, Canon EOS 5D, studio lighting, 8k UHD, sharp focus";

        var seed = (av.Seed * 13 + f.Id.GetHashCode()) & 0x7FFFFFFF;
        return "https://image.pollinations.ai/prompt/" +
               Uri.EscapeDataString(prompt) +
               "?width=480&height=720&model=flux&seed=" + seed + "&nologo=true&enhance=true";
    }

    static string CorIngles(string cores)
    {
        var c = cores.ToLower();
        if (c.Contains("azul") && c.Contains("mar")) return "dark navy blue";
        if (c.Contains("azul") && c.Contains("roy")) return "royal blue";
        if (c.Contains("azul") && c.Contains("cla")) return "light sky blue";
        if (c.Contains("azul"))   return "blue";
        if (c.Contains("bran"))   return "white";
        if (c.Contains("pre"))    return "black";
        if (c.Contains("cza") || c.Contains("gray") || c.Contains("grey")) return "gray";
        if (c.Contains("verm"))   return "red";
        if (c.Contains("bord") || c.Contains("vinh")) return "dark burgundy red";
        if (c.Contains("rosa"))   return "pink";
        if (c.Contains("verde") && c.Contains("mil")) return "military olive green";
        if (c.Contains("verde"))  return "green";
        if (c.Contains("amar"))   return "yellow";
        if (c.Contains("lar"))    return "orange";
        if (c.Contains("rox"))    return "purple";
        if (c.Contains("lilas") || c.Contains("lilá")) return "lilac";
        if (c.Contains("beg") || c.Contains("cru")) return "beige";
        if (c.Contains("mar"))    return "brown";
        return cores;
    }

    static string[] CoresHex(string cores) =>
        cores.ToLower().Split([" e ", " & ", ",", "/"], StringSplitOptions.RemoveEmptyEntries)
             .Select(c => c.Trim() switch
             {
                 var x when x.Contains("bran")  => "#F8F8F8",
                 var x when x.Contains("pre")   => "#111111",
                 var x when x.Contains("cza") || x.Contains("gray") => "#9CA3AF",
                 var x when x.Contains("azul") && x.Contains("mar") => "#1E3A5F",
                 var x when x.Contains("azul") && x.Contains("roy") => "#1D4ED8",
                 var x when x.Contains("azul")  => "#3B82F6",
                 var x when x.Contains("verm")  => "#DC2626",
                 var x when x.Contains("bord") || x.Contains("vinh") => "#7F1D1D",
                 var x when x.Contains("rosa")  => "#F9A8D4",
                 var x when x.Contains("verde") && x.Contains("mil") => "#365314",
                 var x when x.Contains("verde") => "#16A34A",
                 var x when x.Contains("amar")  => "#EAB308",
                 var x when x.Contains("lar")   => "#EA580C",
                 var x when x.Contains("rox")   => "#7C3AED",
                 var x when x.Contains("mar")   => "#92400E",
                 _ => "#6B7280"
             }).ToArray();

    static string NomeTipo(Models.TipoProduto t) => t switch
    {
        Models.TipoProduto.CamisaPolo  => "Camisa Polo",
        Models.TipoProduto.CamisaMalha => "Camiseta Malha",
        Models.TipoProduto.Jaleco      => "Jaleco",
        Models.TipoProduto.Calca       => "Calça",
        Models.TipoProduto.Bermuda     => "Bermuda",
        Models.TipoProduto.Agasalho    => "Agasalho",
        Models.TipoProduto.Colete      => "Colete",
        _ => t.ToString()
    };

    static string NomeTipoEn(Models.TipoProduto t) => t switch
    {
        Models.TipoProduto.CamisaPolo  => "polo shirt",
        Models.TipoProduto.CamisaMalha => "t-shirt",
        Models.TipoProduto.Jaleco      => "work jacket",
        Models.TipoProduto.Calca       => "pants",
        Models.TipoProduto.Bermuda     => "shorts",
        Models.TipoProduto.Agasalho    => "tracksuit jacket",
        Models.TipoProduto.Colete      => "vest",
        _ => t.ToString().ToLower()
    };

    static string NomeLogomarca(Models.TipoLogomarca t) => t switch
    {
        Models.TipoLogomarca.Bordado    => "Bordado",
        Models.TipoLogomarca.SilkScreen => "Silk Screen",
        Models.TipoLogomarca.Sublimacao => "Sublimação",
        Models.TipoLogomarca.Transfer   => "Transfer",
        _ => t.ToString()
    };

    static string NomeLogomarcaEn(Models.TipoLogomarca t) => t switch
    {
        Models.TipoLogomarca.Bordado    => "embroidered",
        Models.TipoLogomarca.SilkScreen => "silk screen printed",
        Models.TipoLogomarca.Sublimacao => "sublimation printed",
        Models.TipoLogomarca.Transfer   => "heat transfer",
        _ => ""
    };

    // ── State ─────────────────────────────────
    Etapa etapa = Etapa.Avatares;
    List<Models.LayoutDto> fichas = [];
    AvatarDef? avatarAtual;
    Models.LayoutDto? fichaAtual;
    string imgResultado = "";
    bool carregando = true, gerando, pausado;
    string erroStudio = "";

    // TV slideshow
    int tvIndex = 0;
    bool tvTransition;
    System.Threading.Timer? _tvTimer;

    protected override async Task OnInitializedAsync()
    {
        fichas = await Api.ListarLayoutsAsync();
        carregando = false;
        IniciarTV();
    }

    void IniciarTV()
    {
        _tvTimer = new System.Threading.Timer(async _ =>
        {
            if (pausado || etapa != Etapa.Avatares) return;
            tvTransition = true;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(300);
            tvIndex = (tvIndex + 1) % Avatares.Length;
            tvTransition = false;
            await InvokeAsync(StateHasChanged);
        }, null, 3500, 3500);
    }

    void TogglePause() => pausado = !pausado;

    void SelecionarThumb(int idx)
    {
        tvIndex = idx;
        pausado = true;
    }

    async Task EscolherAvatar(AvatarDef av)
    {
        pausado = true;
        avatarAtual = av;
        fichaAtual = null;
        etapa = Etapa.GuardaRoupa;
        await Task.CompletedTask;
    }

    void VoltarAvatares()
    {
        etapa = Etapa.Avatares;
        avatarAtual = null;
        fichaAtual = null;
        imgResultado = "";
        erroStudio = "";
        pausado = false;
    }

    async Task EscolherRoupa(Models.LayoutDto f)
    {
        fichaAtual = f;
        etapa = Etapa.Resultado;
        await GerarTryOn();
    }

    async Task GerarTryOn()
    {
        if (avatarAtual is null || fichaAtual is null) return;
        gerando = true;
        erroStudio = "";
        imgResultado = TryOnUrl(avatarAtual, fichaAtual);
        StateHasChanged();

        try
        {
            var urls = await JS.InvokeAsync<string[]?>(
                "OutfitAnyone.gerar4Vistas",
                NomeTipoEn(fichaAtual.TipoProduto),
                fichaAtual.Cores,
                fichaAtual.Tecido,
                NomeLogomarcaEn(fichaAtual.TipoLogomarca) + " logo on " + fichaAtual.PosicaoLogomarca);

            if (urls is not null && urls.Length > 0 && !string.IsNullOrEmpty(urls[0]))
                imgResultado = urls[0];
        }
        catch { }

        gerando = false;
        StateHasChanged();
    }

    async Task ImprimirProposta() =>
        await JS.InvokeVoidAsync("window.print");

    public void Dispose() => _tvTimer?.Dispose();
}
