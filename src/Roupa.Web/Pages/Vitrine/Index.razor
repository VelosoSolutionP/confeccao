@page "/vitrine"
@attribute [Authorize]
@inject ApiService Api
@inject IJSRuntime JS

<PageTitle>Vitrine — Uniformes</PageTitle>

<!-- ══ TELA DE DETALHE (estilo e-commerce) ══ -->
@if (detalhe is not null)
{
    <div class="vit-detail-page">
        <!-- Breadcrumb -->
        <div class="vit-breadcrumb">
            <span @onclick="FecharDetalhe" style="cursor:pointer;color:var(--brand-500)">
                <i class="bi bi-grid-3x3-gap-fill"></i> Vitrine
            </span>
            <i class="bi bi-chevron-right" style="font-size:.7rem;color:var(--surface-400)"></i>
            <span style="color:var(--surface-600)">@NomeTipo(detalhe.TipoProduto)</span>
            <i class="bi bi-chevron-right" style="font-size:.7rem;color:var(--surface-400)"></i>
            <span style="color:var(--surface-800);font-weight:600">@detalhe.Modelo</span>
        </div>

        <div class="vit-detail-layout">

            <!-- ── COLUNA ESQUERDA: galeria de imagens ── -->
            <div class="vit-galeria">
                <!-- Thumbnails lateral -->
                <div class="vit-thumbs">
                    @foreach (var (ang, idx) in Angulos.Select((a, i) => (a, i)))
                    {
                        var i2 = idx;
                        <div class="vit-thumb @(anguloAtual == i2 ? "ativo" : "")"
                             @onclick="() => { anguloAtual = i2; girando = false; }">
                            <img src="@CartoonUrl(detalhe, corAtual, ang.Key, true)"
                                 alt="@ang.Value" loading="lazy"
                                 onerror="this.src='/img/placeholder.svg'" />
                            <span>@ang.Value</span>
                        </div>
                    }
                    <!-- Flat lay -->
                    <div class="vit-thumb @(anguloAtual == 4 ? "ativo" : "")"
                         @onclick="() => { anguloAtual = 4; girando = false; }">
                        <img src="@FlatLayUrl(detalhe, corAtual)"
                             alt="Flat" loading="lazy"
                             onerror="this.src='/img/placeholder.svg'" />
                        <span>Flat lay</span>
                    </div>
                </div>

                <!-- Imagem principal -->
                <div class="vit-main-img">
                    <img src="@ImgPrincipal()"
                         alt="@detalhe.Modelo — @corAtual"
                         onerror="this.src='/img/placeholder.svg'"
                         key="@(detalhe.Id + corAtual + anguloAtual)" />

                    @if (detalhe.Aprovado)
                    {
                        <div class="vit-main-badge">
                            <i class="bi bi-check-circle-fill"></i> Aprovado
                        </div>
                    }

                    <!-- Setas de ângulo -->
                    <button class="vit-arrow left" @onclick="() => NavAngulo(-1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <button class="vit-arrow right" @onclick="() => NavAngulo(1)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>

            <!-- ── COLUNA DIREITA: info + cores ── -->
            <div class="vit-info-col">
                <div class="vit-info-tipo">@NomeTipo(detalhe.TipoProduto)</div>
                <h1 class="vit-info-nome">@detalhe.Modelo</h1>
                <div class="vit-info-cliente">
                    <i class="bi bi-buildings"></i> @detalhe.NomeCliente
                </div>
                <div class="vit-info-tecido">
                    <i class="bi bi-layers"></i> @detalhe.Tecido
                </div>

                <div class="vit-sep"></div>

                <!-- Cor selecionada -->
                <div class="vit-cor-titulo">
                    Cor: <strong>@corAtual</strong>
                </div>

                <!-- Swatches de cor (estilo Posthaus) -->
                <div class="vit-swatches">
                    @foreach (var cor in CoresDisponiveis(detalhe))
                    {
                        var c = cor;
                        var hex = CorHex(c);
                        <button class="vit-swatch @(corAtual == c ? "ativo" : "")"
                                style="background:@hex"
                                title="@c"
                                @onclick="() => MudarCor(c)">
                            @if (corAtual == c)
                            {
                                <i class="bi bi-check-lg" style="color:@CorFg(hex);font-size:.75rem"></i>
                            }
                        </button>
                    }
                </div>

                <div class="vit-sep"></div>

                <!-- Detalhes técnicos -->
                <div class="vit-specs">
                    <div class="vit-spec-row">
                        <span>Aplicação de logo</span>
                        <strong>@NomeLogomarca(detalhe.TipoLogomarca)</strong>
                    </div>
                    <div class="vit-spec-row">
                        <span>Posição</span>
                        <strong>@detalhe.PosicaoLogomarca</strong>
                    </div>
                    @if (!string.IsNullOrEmpty(detalhe.TamanhoLogomarca))
                    {
                        <div class="vit-spec-row">
                            <span>Tamanho logo</span>
                            <strong>@detalhe.TamanhoLogomarca</strong>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(detalhe.CorLogomarca))
                    {
                        <div class="vit-spec-row">
                            <span>Cor do logo</span>
                            <strong>@detalhe.CorLogomarca</strong>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(detalhe.Outros))
                    {
                        <div class="vit-spec-row obs">
                            <span>Observações</span>
                            <strong>@detalhe.Outros</strong>
                        </div>
                    }
                </div>

                <div class="vit-sep"></div>

                <!-- Botões de ação -->
                <div class="vit-acoes">
                    <button class="vit-btn-360 @(girando ? "ativo" : "")" @onclick="ToggleGiro">
                        <i class="bi @(girando ? "bi-pause-fill" : "bi-arrow-repeat")"></i>
                        @(girando ? "Pausar giro" : "Girar 360°")
                    </button>
                    <a class="vit-btn-baixar"
                       href="@ImgPrincipal()"
                       download="@($"{detalhe.Modelo}_{corAtual}.jpg")"
                       target="_blank">
                        <i class="bi bi-download"></i> Baixar imagem
                    </a>
                    <button class="vit-btn-pdf" @onclick="ImprimirProposta">
                        <i class="bi bi-file-earmark-pdf-fill"></i> Proposta PDF
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- ══ LISTAGEM ══ -->
    <div class="page-header">
        <div>
            <div class="page-title">Vitrine de Uniformes</div>
            <div class="page-subtitle">Clique em um produto para ver no personagem e trocar cores</div>
        </div>
        <div style="display:flex;gap:.6rem;flex-wrap:wrap">
            <input class="input-field" style="width:200px;font-size:.85rem"
                   placeholder="Buscar..." @bind="busca" @bind:event="oninput" />
            <select class="input-field" style="width:150px;font-size:.85rem;appearance:auto"
                    @bind="filtroTipo">
                <option value="">Todos os tipos</option>
                @foreach (var tp in Enum.GetValues<Models.TipoProduto>())
                {
                    <option value="@((int)tp)">@NomeTipo(tp)</option>
                }
            </select>
        </div>
    </div>

    @if (carregando)
    {
        <div class="vit-skeleton-grid">
            @for (var i = 0; i < 8; i++)
            {
                <div class="vit-skeleton-card">
                    <div class="vit-sk-img"></div>
                    <div class="vit-sk-line"></div>
                    <div class="vit-sk-line short"></div>
                    <div class="vit-sk-cores"></div>
                </div>
            }
        </div>
    }
    else if (!ProdutosFiltrados().Any())
    {
        <div class="card-modern">
            <div class="empty-state">
                <i class="bi bi-bag-x"></i>
                <p>Nenhum produto encontrado.</p>
                <a href="/layouts" class="btn-primary-modern mt-3">
                    <i class="bi bi-plus-lg"></i> Cadastrar fichas
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="vit-grid">
            @foreach (var p in ProdutosFiltrados())
            {
                var cores = CoresDisponiveis(p).ToList();
                var corCard = cores.FirstOrDefault() ?? p.Cores;
                <div class="vit-card" @onclick="() => AbrirDetalhe(p)">
                    <div class="vit-card-img">
                        <img src="@CartoonUrl(p, corCard, "front", false)"
                             alt="@p.Modelo"
                             loading="lazy"
                             onerror="this.src='/img/placeholder.svg'" />
                        <div class="vit-card-overlay">
                            <i class="bi bi-eye-fill"></i> Ver produto
                        </div>
                        @if (p.Aprovado)
                        {
                            <div class="vit-badge-card">
                                <i class="bi bi-check-circle-fill"></i> Aprovado
                            </div>
                        }
                    </div>
                    <div class="vit-card-body">
                        <div class="vit-card-tipo">@NomeTipo(p.TipoProduto)</div>
                        <div class="vit-card-nome">@p.Modelo</div>
                        <div class="vit-card-cliente">@p.NomeCliente</div>
                        <div class="vit-card-swatches">
                            @foreach (var c in cores.Take(5))
                            {
                                <span class="vit-mini-swatch" style="background:@CorHex(c)" title="@c"></span>
                            }
                            @if (cores.Count > 5)
                            {
                                <span class="vit-mini-mais">+@(cores.Count - 5)</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

<!-- PRINT -->
@if (detalhe is not null)
{
    <div class="proposta-print">
        <div class="proposta-header">
            <div class="proposta-logo"><i class="bi bi-scissors"></i> Roupa Solution</div>
            <div class="proposta-titulo">PROPOSTA DE UNIFORME</div>
            <div class="proposta-data">@DateTime.Now.ToString("dd/MM/yyyy")</div>
        </div>
        <div class="proposta-body">
            <img src="@ImgPrincipal()" class="proposta-avatar-img" />
            <div class="proposta-detalhes">
                <h2>@detalhe.Modelo</h2>
                <p><b>Cliente:</b> @detalhe.NomeCliente</p>
                <p><b>Tipo:</b> @NomeTipo(detalhe.TipoProduto)</p>
                <p><b>Tecido:</b> @detalhe.Tecido</p>
                <p><b>Cor:</b> @corAtual</p>
                <p><b>Logomarca:</b> @NomeLogomarca(detalhe.TipoLogomarca) — @detalhe.PosicaoLogomarca</p>
                @if (!string.IsNullOrWhiteSpace(detalhe.Outros))
                {
                    <p><b>Obs:</b> @detalhe.Outros</p>
                }
            </div>
        </div>
        <div class="proposta-footer">Roupa Solution — Gestão Têxtil Profissional</div>
    </div>
}

@code {
    // ── Ângulos disponíveis ───────────────────────────────
    static readonly (string Key, string Value)[] Angulos =
    [
        ("front",  "Frente"),
        ("right",  "Lado"),
        ("back",   "Costas"),
        ("detail", "Detalhe"),
    ];

    // ── Estado ────────────────────────────────────────────
    List<Models.LayoutDto> produtos  = [];
    Models.LayoutDto?      detalhe;
    bool  carregando = true;
    string busca      = "";
    string filtroTipo = "";

    // Detalhe
    string corAtual    = "";
    int    anguloAtual = 0;
    bool   girando     = false;
    System.Threading.Timer? _giroTimer;

    // ── Init ──────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        produtos    = await Api.ListarLayoutsAsync();
        carregando  = false;
    }

    // ── Filtros ───────────────────────────────────────────
    IEnumerable<Models.LayoutDto> ProdutosFiltrados()
    {
        var q = produtos.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(busca))
            q = q.Where(p => p.Modelo.Contains(busca, StringComparison.OrdinalIgnoreCase)
                          || p.NomeCliente.Contains(busca, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrWhiteSpace(filtroTipo) && int.TryParse(filtroTipo, out var tp))
            q = q.Where(p => (int)p.TipoProduto == tp);
        return q;
    }

    // ── Detalhe ───────────────────────────────────────────
    void AbrirDetalhe(Models.LayoutDto p)
    {
        detalhe    = p;
        corAtual   = CoresDisponiveis(p).FirstOrDefault() ?? p.Cores;
        anguloAtual = 0;
        girando    = false;
    }

    void FecharDetalhe()
    {
        _giroTimer?.Dispose();
        _giroTimer = null;
        girando = false;
        detalhe = null;
    }

    void MudarCor(string cor)
    {
        corAtual    = cor;
        anguloAtual = 0;
    }

    void NavAngulo(int delta)
    {
        anguloAtual = ((anguloAtual + delta) % 5 + 5) % 5;
        girando = false;
    }

    void ToggleGiro()
    {
        girando = !girando;
        if (girando)
        {
            _giroTimer = new System.Threading.Timer(async _ =>
            {
                if (!girando) return;
                anguloAtual = (anguloAtual + 1) % 4; // só os 4 ângulos do personagem
                await InvokeAsync(StateHasChanged);
            }, null, 1400, 1400);
        }
        else
        {
            _giroTimer?.Dispose();
            _giroTimer = null;
        }
    }

    string ImgPrincipal()
    {
        if (detalhe is null) return "/img/placeholder.svg";
        if (anguloAtual == 4) return FlatLayUrl(detalhe, corAtual);
        return CartoonUrl(detalhe, corAtual, Angulos[anguloAtual].Key, false);
    }

    async Task ImprimirProposta() =>
        await JS.InvokeVoidAsync("window.print");

    // ── Cores ─────────────────────────────────────────────
    static List<string> CoresDisponiveis(Models.LayoutDto p) =>
        p.Cores
         .Split([" e ", " & ", ",", "/"], StringSplitOptions.RemoveEmptyEntries)
         .Select(c => c.Trim())
         .Where(c => !string.IsNullOrEmpty(c))
         .Distinct()
         .ToList();

    // ── URLs Pollinations ─────────────────────────────────

    // Personagem cartoon vestindo a peça
    static string CartoonUrl(Models.LayoutDto p, string cor, string angulo, bool thumb)
    {
        var tipo  = NomeTipoEn(p.TipoProduto);
        var corEn = CorIngles(cor);
        var logo  = NomeLogomarcaEn(p.TipoLogomarca) + " logo on " + p.PosicaoLogomarca;

        var viewDesc = angulo switch
        {
            "front"  => "facing forward, full body",
            "right"  => "turned to the right side, 3/4 view",
            "back"   => "back view, full body",
            "detail" => "close-up upper body, detail view",
            _        => "full body front view"
        };

        var prompt = "3D cartoon character illustration, friendly animated person, " +
                     "Pixar Disney style, stylized proportions, " +
                     "wearing a " + tipo + ", " +
                     "solid opaque " + corEn + " color, smooth fabric, " +
                     logo + ", " +
                     viewDesc + ", " +
                     "clean pure white background, professional product photography lighting, " +
                     "vibrant colors, high quality render, no text";

        var w    = thumb ? 120 : 600;
        var h    = thumb ? 160 : 800;
        var seed = (p.Id.GetHashCode() * 31 + angulo.GetHashCode() * 17 + cor.GetHashCode()) & 0x7FFFFFFF;

        return "https://image.pollinations.ai/prompt/" +
               Uri.EscapeDataString(prompt) +
               "?width=" + w + "&height=" + h +
               "&model=flux&seed=" + seed + "&nologo=true&enhance=true";
    }

    // Flat lay (vista de cima)
    static string FlatLayUrl(Models.LayoutDto p, string cor)
    {
        var tipo  = NomeTipoEn(p.TipoProduto);
        var corEn = CorIngles(cor);
        var prompt = "flat lay product photography, " + tipo +
                     ", solid opaque " + corEn + " color, " + p.Tecido + " fabric" +
                     ", pure white background, top down view, no shadows, 8k, vibrant";
        var seed = (p.Id.GetHashCode() + 88888) & 0x7FFFFFFF;
        return "https://image.pollinations.ai/prompt/" +
               Uri.EscapeDataString(prompt) +
               "?width=600&height=800&model=flux&seed=" + seed + "&nologo=true";
    }

    // ── Mapeamentos ───────────────────────────────────────
    static string CorIngles(string c)
    {
        var s = c.ToLower();
        if (s.Contains("azul") && s.Contains("mar")) return "dark navy blue";
        if (s.Contains("azul") && s.Contains("roy")) return "royal blue";
        if (s.Contains("azul") && s.Contains("cla")) return "light sky blue";
        if (s.Contains("azul"))   return "blue";
        if (s.Contains("bran"))   return "white";
        if (s.Contains("pre"))    return "black";
        if (s.Contains("cza") || s.Contains("gray")) return "gray";
        if (s.Contains("verm"))   return "red";
        if (s.Contains("bord") || s.Contains("vinh")) return "dark burgundy red";
        if (s.Contains("rosa"))   return "pink";
        if (s.Contains("verde") && s.Contains("mil")) return "military olive green";
        if (s.Contains("verde"))  return "green";
        if (s.Contains("amar"))   return "yellow";
        if (s.Contains("lar"))    return "orange";
        if (s.Contains("rox"))    return "purple";
        if (s.Contains("lilas") || s.Contains("lilá")) return "lilac";
        if (s.Contains("beg") || s.Contains("cru")) return "beige";
        if (s.Contains("mar"))    return "brown";
        return c;
    }

    static string CorHex(string c)
    {
        var s = c.ToLower();
        if (s.Contains("bran"))  return "#F8F8F8";
        if (s.Contains("pre"))   return "#111111";
        if (s.Contains("cza") || s.Contains("gray")) return "#9CA3AF";
        if (s.Contains("azul") && s.Contains("mar"))  return "#1E3A5F";
        if (s.Contains("azul") && s.Contains("roy"))  return "#1D4ED8";
        if (s.Contains("azul")) return "#3B82F6";
        if (s.Contains("verm")) return "#DC2626";
        if (s.Contains("bord") || s.Contains("vinh")) return "#7F1D1D";
        if (s.Contains("rosa")) return "#F9A8D4";
        if (s.Contains("verde") && s.Contains("mil")) return "#365314";
        if (s.Contains("verde")) return "#16A34A";
        if (s.Contains("amar")) return "#EAB308";
        if (s.Contains("lar"))  return "#EA580C";
        if (s.Contains("rox"))  return "#7C3AED";
        if (s.Contains("lilas") || s.Contains("lilá")) return "#C4B5FD";
        if (s.Contains("beg") || s.Contains("cru")) return "#D4A574";
        if (s.Contains("mar"))  return "#92400E";
        return "#6B7280";
    }

    static string CorFg(string hex)
    {
        var dark = new[] { "#111111","#1E3A5F","#1D4ED8","#7F1D1D","#365314","#7C3AED","#92400E","#DC2626","#EA580C","#16A34A" };
        return dark.Contains(hex) ? "#fff" : "#111";
    }

    static string NomeTipo(Models.TipoProduto t) => t switch
    {
        Models.TipoProduto.CamisaPolo  => "Camisa Polo",
        Models.TipoProduto.CamisaMalha => "Camiseta Malha",
        Models.TipoProduto.Jaleco      => "Jaleco",
        Models.TipoProduto.Calca       => "Calça",
        Models.TipoProduto.Bermuda     => "Bermuda",
        Models.TipoProduto.Agasalho    => "Agasalho",
        Models.TipoProduto.Colete      => "Colete",
        _ => t.ToString()
    };

    static string NomeTipoEn(Models.TipoProduto t) => t switch
    {
        Models.TipoProduto.CamisaPolo  => "polo shirt",
        Models.TipoProduto.CamisaMalha => "t-shirt",
        Models.TipoProduto.Jaleco      => "work jacket",
        Models.TipoProduto.Calca       => "pants",
        Models.TipoProduto.Bermuda     => "shorts",
        Models.TipoProduto.Agasalho    => "tracksuit",
        Models.TipoProduto.Colete      => "vest",
        _ => t.ToString().ToLower()
    };

    static string NomeLogomarca(Models.TipoLogomarca t) => t switch
    {
        Models.TipoLogomarca.Bordado    => "Bordado",
        Models.TipoLogomarca.SilkScreen => "Silk Screen",
        Models.TipoLogomarca.Sublimacao => "Sublimação",
        Models.TipoLogomarca.Transfer   => "Transfer",
        _ => t.ToString()
    };

    static string NomeLogomarcaEn(Models.TipoLogomarca t) => t switch
    {
        Models.TipoLogomarca.Bordado    => "embroidered",
        Models.TipoLogomarca.SilkScreen => "silk screen printed",
        Models.TipoLogomarca.Sublimacao => "sublimation printed",
        Models.TipoLogomarca.Transfer   => "heat transfer",
        _ => ""
    };
}
