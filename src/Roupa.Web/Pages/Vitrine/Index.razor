@page "/vitrine"
@attribute [Authorize]
@inject ApiService Api
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Vitrine — Uniformes</PageTitle>

<!-- ══ PÁGINA DE DETALHE ══ -->
@if (detalhe is not null)
{
    <div class="vit-detail-page">
        <div class="vit-breadcrumb">
            <span @onclick="FecharDetalhe"><i class="bi bi-grid-3x3-gap-fill"></i> Vitrine</span>
            <i class="bi bi-chevron-right"></i>
            <span>@NomeTipo(detalhe.TipoProduto)</span>
            <i class="bi bi-chevron-right"></i>
            <strong>@detalhe.Modelo</strong>
        </div>

        <div class="vit-detail-layout">

            <!-- ── Coluna esquerda: personagem ── -->
            <div class="vit-galeria-col">
                <!-- Botões de vista -->
                <div class="vit-view-tabs">
                    @foreach (var (v, lbl) in new[]{("frente","Frente"),("lado","Lado D"),("costas","Costas"),("lado-e","Lado E")})
                    {
                        var vv = v; var ll = lbl;
                        <button class="vit-view-tab @(vistaAtual == vv ? "ativo" : "")"
                                @onclick="() => { vistaAtual = vv; girando = false; PararTimer(); }">
                            @ll
                        </button>
                    }
                </div>

                <!-- Personagem SVG -->
                <div class="vit-char-container">
                    <Personagem ShirtColor="@shirtHex"
                                PantsColor="@pantsHex"
                                ShoesColor="@shoesHex"
                                LogoColor="@logoHex"
                                Spinning="@girando"
                                ViewLabel="@NomeVista(vistaAtual)" />

                    <!-- Overlay "gerando..." aparece somente se não tiver cor ainda -->
                    @if (string.IsNullOrEmpty(shirtHex))
                    {
                        <div class="vit-char-loading">
                            <div class="vit-spin-icon"></div>
                        </div>
                    }
                </div>

                <!-- Botão 360° -->
                <button class="vit-btn-360 @(girando ? "ativo" : "")" @onclick="ToggleGiro">
                    <i class="bi @(girando ? "bi-pause-fill" : "bi-arrow-repeat")"></i>
                    @(girando ? "Pausar rotação" : "Girar 360°")
                </button>
            </div>

            <!-- ── Coluna direita: info ── -->
            <div class="vit-info-col">
                <div class="vit-info-tag">@NomeTipo(detalhe.TipoProduto)</div>
                <h1 class="vit-info-nome">@detalhe.Modelo</h1>
                <div class="vit-info-sub">
                    <i class="bi bi-buildings"></i> @detalhe.NomeCliente
                    &nbsp;·&nbsp;
                    <i class="bi bi-layers"></i> @detalhe.Tecido
                </div>

                @if (detalhe.Aprovado)
                {
                    <div class="vit-aprovado-badge">
                        <i class="bi bi-check-circle-fill"></i> FICHA APROVADA
                    </div>
                }

                <div class="vit-sep"></div>

                <!-- COR DA CAMISA -->
                <div class="vit-cor-grupo">
                    <div class="vit-cor-label">
                        Cor da camisa
                        <span class="vit-cor-selected" style="background:@shirtHex">
                            <span style="color:@CorFg(shirtHex)">@shirtNome</span>
                        </span>
                    </div>
                    <div class="vit-swatches">
                        @foreach (var cor in CoresDisponiveis(detalhe))
                        {
                            var c = cor;
                            var hex = CorHex(c);
                            <button class="vit-swatch @(shirtNome == c ? "ativo" : "")"
                                    style="background:@hex"
                                    title="@c"
                                    @onclick="() => { shirtNome = c; shirtHex = CorHex(c); }">
                                @if (shirtNome == c)
                                {
                                    <i class="bi bi-check-lg" style="color:@CorFg(hex)"></i>
                                }
                            </button>
                        }
                    </div>
                </div>

                <!-- COR DA CALÇA -->
                <div class="vit-cor-grupo">
                    <div class="vit-cor-label">
                        Cor da calça
                        <span class="vit-cor-selected" style="background:@pantsHex">
                            <span style="color:@CorFg(pantsHex)">@pantsNome</span>
                        </span>
                    </div>
                    <div class="vit-swatches">
                        @foreach (var cor in CoresCalca)
                        {
                            var c = cor.Nome; var hex = cor.Hex;
                            <button class="vit-swatch @(pantsNome == c ? "ativo" : "")"
                                    style="background:@hex"
                                    title="@c"
                                    @onclick="() => { pantsNome = c; pantsHex = hex; }">
                                @if (pantsNome == c)
                                {
                                    <i class="bi bi-check-lg" style="color:@CorFg(hex)"></i>
                                }
                            </button>
                        }
                    </div>
                </div>

                <!-- COR DO SAPATO -->
                <div class="vit-cor-grupo">
                    <div class="vit-cor-label">
                        Cor do sapato
                        <span class="vit-cor-selected" style="background:@shoesHex">
                            <span style="color:@CorFg(shoesHex)">@shoesNome</span>
                        </span>
                    </div>
                    <div class="vit-swatches">
                        @foreach (var cor in CoresSapato)
                        {
                            var c = cor.Nome; var hex = cor.Hex;
                            <button class="vit-swatch @(shoesNome == c ? "ativo" : "")"
                                    style="background:@hex"
                                    title="@c"
                                    @onclick="() => { shoesNome = c; shoesHex = hex; }">
                                @if (shoesNome == c)
                                {
                                    <i class="bi bi-check-lg" style="color:@CorFg(hex)"></i>
                                }
                            </button>
                        }
                    </div>
                </div>

                <div class="vit-sep"></div>

                <!-- Detalhes técnicos -->
                <div class="vit-specs">
                    <div class="vit-spec"><span>Aplicação</span><strong>@NomeLogomarca(detalhe.TipoLogomarca)</strong></div>
                    <div class="vit-spec"><span>Posição logo</span><strong>@detalhe.PosicaoLogomarca</strong></div>
                    @if (!string.IsNullOrEmpty(detalhe.TamanhoLogomarca))
                    {
                        <div class="vit-spec"><span>Tamanho logo</span><strong>@detalhe.TamanhoLogomarca</strong></div>
                    }
                    @if (!string.IsNullOrEmpty(detalhe.CorLogomarca))
                    {
                        <div class="vit-spec"><span>Cor logo</span><strong>@detalhe.CorLogomarca</strong></div>
                    }
                    @if (!string.IsNullOrEmpty(detalhe.Outros))
                    {
                        <div class="vit-spec obs"><span>Observações</span><span>@detalhe.Outros</span></div>
                    }
                </div>

                <div class="vit-sep"></div>

                <div class="vit-acoes">
                    <button class="vit-btn-pdf" @onclick="ImprimirProposta">
                        <i class="bi bi-file-earmark-pdf-fill"></i> Gerar Proposta PDF
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- ══ LISTAGEM ══ -->
    <div class="page-header">
        <div>
            <div class="page-title">Vitrine de Uniformes</div>
            <div class="page-subtitle">Clique em um produto para vestir no personagem e trocar as cores</div>
        </div>
        <div style="display:flex;gap:.6rem;flex-wrap:wrap">
            <input class="input-field" style="width:200px;font-size:.85rem"
                   placeholder="Buscar..." @bind="busca" @bind:event="oninput" />
            <select class="input-field" style="width:150px;font-size:.85rem;appearance:auto"
                    @bind="filtroTipo">
                <option value="">Todos os tipos</option>
                @foreach (var tp in Enum.GetValues<Models.TipoProduto>())
                {
                    <option value="@((int)tp)">@NomeTipo(tp)</option>
                }
            </select>
        </div>
    </div>

    @if (carregando)
    {
        <div class="vit-skeleton-grid">
            @for (var i = 0; i < 8; i++)
            {
                <div class="vit-skeleton-card">
                    <div class="vit-sk-img"></div>
                    <div class="vit-sk-line"></div>
                    <div class="vit-sk-line short"></div>
                    <div class="vit-sk-cores"></div>
                </div>
            }
        </div>
    }
    else if (!ProdutosFiltrados().Any())
    {
        <div class="card-modern">
            <div class="empty-state">
                <i class="bi bi-bag-x"></i>
                <p>Nenhum produto encontrado.</p>
                <a href="/layouts" class="btn-primary-modern mt-3">
                    <i class="bi bi-plus-lg"></i> Cadastrar fichas
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="vit-grid">
            @foreach (var p in ProdutosFiltrados())
            {
                var primeirasCores = CoresDisponiveis(p);
                var corCard = primeirasCores.FirstOrDefault() ?? "";
                <div class="vit-card" @onclick="() => AbrirDetalhe(p)">
                    <!-- Preview SVG miniatura -->
                    <div class="vit-card-img">
                        <div class="vit-card-svg-wrap"
                             style="--shirt:@CorHex(corCard);--pants:#1E3A5F;--shoes:#2D2D2D;--logo:#fff">
                            <Personagem ShirtColor="@CorHex(corCard)"
                                        PantsColor="#1E3A5F"
                                        ShoesColor="#2D2D2D"
                                        LogoColor="#FFFFFF" />
                        </div>
                        <div class="vit-card-overlay">
                            <i class="bi bi-eye-fill"></i> Experimentar
                        </div>
                        @if (p.Aprovado)
                        {
                            <div class="vit-badge-card">
                                <i class="bi bi-check-circle-fill"></i> Aprovado
                            </div>
                        }
                    </div>
                    <div class="vit-card-body">
                        <div class="vit-card-tipo">@NomeTipo(p.TipoProduto)</div>
                        <div class="vit-card-nome">@p.Modelo</div>
                        <div class="vit-card-cliente">@p.NomeCliente</div>
                        <div class="vit-card-swatches">
                            @foreach (var c in primeirasCores.Take(6))
                            {
                                <span class="vit-mini-swatch" style="background:@CorHex(c)" title="@c"></span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

<!-- PRINT -->
@if (detalhe is not null)
{
    <div class="proposta-print">
        <div class="proposta-header">
            <div class="proposta-logo"><i class="bi bi-scissors"></i> Roupa Solution</div>
            <div class="proposta-titulo">PROPOSTA DE UNIFORME</div>
            <div class="proposta-data">@DateTime.Now.ToString("dd/MM/yyyy")</div>
        </div>
        <div class="proposta-body">
            <div class="proposta-avatar-img" style="width:200px;height:300px">
                <Personagem ShirtColor="@shirtHex" PantsColor="@pantsHex"
                            ShoesColor="@shoesHex" LogoColor="@logoHex" />
            </div>
            <div class="proposta-detalhes">
                <h2>@detalhe.Modelo</h2>
                <p><b>Cliente:</b> @detalhe.NomeCliente</p>
                <p><b>Tipo:</b> @NomeTipo(detalhe.TipoProduto)</p>
                <p><b>Tecido:</b> @detalhe.Tecido</p>
                <p><b>Camisa:</b> @shirtNome</p>
                <p><b>Calça:</b> @pantsNome</p>
                <p><b>Sapato:</b> @shoesNome</p>
                <p><b>Logomarca:</b> @NomeLogomarca(detalhe.TipoLogomarca) — @detalhe.PosicaoLogomarca</p>
                @if (!string.IsNullOrWhiteSpace(detalhe.Outros))
                {
                    <p><b>Obs:</b> @detalhe.Outros</p>
                }
            </div>
        </div>
        <div class="proposta-footer">Roupa Solution — Gestão Têxtil Profissional</div>
    </div>
}

@code {
    // ── Paletas fixas ─────────────────────────────────────
    record CorOpc(string Nome, string Hex);

    static readonly CorOpc[] CoresCalca =
    [
        new("Azul Marinho",  "#1E3A5F"),
        new("Preto",         "#111111"),
        new("Cinza",         "#6B7280"),
        new("Cáqui",         "#C5A55A"),
        new("Marrom",        "#92400E"),
        new("Branco",        "#F5F5F5"),
    ];

    static readonly CorOpc[] CoresSapato =
    [
        new("Preto",    "#1A1A1A"),
        new("Marrom",   "#7C4E28"),
        new("Branco",   "#F0F0F0"),
        new("Cinza",    "#808080"),
        new("Caramelo", "#C87941"),
    ];

    // ── Estado ────────────────────────────────────────────
    List<Models.LayoutDto> produtos  = [];
    Models.LayoutDto?      detalhe;
    bool  carregando = true;
    string busca      = "";
    string filtroTipo = "";

    // Cores selecionadas
    string shirtNome = ""; string shirtHex = "#DC2626";
    string pantsNome = "Azul Marinho"; string pantsHex = "#1E3A5F";
    string shoesNome = "Preto";        string shoesHex = "#1A1A1A";
    string logoHex   = "#FFFFFF";

    // Vista e rotação
    string vistaAtual = "frente";
    bool   girando    = false;
    System.Threading.Timer? _timer;
    static readonly string[] VistasCiclo = ["frente", "lado", "costas", "lado-e"];

    // ── Init ──────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        produtos   = await Api.ListarLayoutsAsync();
        carregando = false;
    }

    public void Dispose() => PararTimer();

    // ── Filtros ───────────────────────────────────────────
    IEnumerable<Models.LayoutDto> ProdutosFiltrados()
    {
        var q = produtos.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(busca))
            q = q.Where(p => p.Modelo.Contains(busca, StringComparison.OrdinalIgnoreCase)
                          || p.NomeCliente.Contains(busca, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrWhiteSpace(filtroTipo) && int.TryParse(filtroTipo, out var tp))
            q = q.Where(p => (int)p.TipoProduto == tp);
        return q;
    }

    // ── Detalhe ───────────────────────────────────────────
    void AbrirDetalhe(Models.LayoutDto p)
    {
        detalhe    = p;
        vistaAtual = "frente";
        girando    = false;
        var cores = CoresDisponiveis(p);
        shirtNome  = cores.FirstOrDefault() ?? "";
        shirtHex   = CorHex(shirtNome);
        pantsNome  = "Azul Marinho"; pantsHex = "#1E3A5F";
        shoesNome  = "Preto";        shoesHex = "#1A1A1A";
        logoHex    = "#FFFFFF";
    }

    void FecharDetalhe() { PararTimer(); girando = false; detalhe = null; }

    // ── Rotação 360° ─────────────────────────────────────
    void ToggleGiro()
    {
        girando = !girando;
        if (girando)
        {
            _timer = new System.Threading.Timer(async _ =>
            {
                if (!girando) return;
                var idx  = Array.IndexOf(VistasCiclo, vistaAtual);
                vistaAtual = VistasCiclo[(idx + 1) % VistasCiclo.Length];
                await InvokeAsync(StateHasChanged);
            }, null, 900, 900);
        }
        else PararTimer();
    }

    void PararTimer() { _timer?.Dispose(); _timer = null; }

    string NomeVista(string v) => v switch
    {
        "frente" => "Frente",
        "lado"   => "Lado direito",
        "costas" => "Costas",
        "lado-e" => "Lado esquerdo",
        _        => v
    };

    async Task ImprimirProposta() => await JS.InvokeVoidAsync("window.print");

    // ── Helpers ───────────────────────────────────────────
    static List<string> CoresDisponiveis(Models.LayoutDto p) =>
        p.Cores.Split([" e ", " & ", ",", "/"], StringSplitOptions.RemoveEmptyEntries)
               .Select(c => c.Trim()).Where(c => !string.IsNullOrEmpty(c))
               .Distinct().ToList();

    static string CorHex(string c)
    {
        var s = c.ToLower();
        if (s.Contains("bran"))  return "#F5F5F5";
        if (s.Contains("pre"))   return "#111111";
        if (s.Contains("cza") || s.Contains("gray")) return "#9CA3AF";
        if (s.Contains("azul") && s.Contains("mar")) return "#1E3A5F";
        if (s.Contains("azul") && s.Contains("roy")) return "#1D4ED8";
        if (s.Contains("azul")) return "#3B82F6";
        if (s.Contains("verm")) return "#DC2626";
        if (s.Contains("bord") || s.Contains("vinh")) return "#7F1D1D";
        if (s.Contains("rosa")) return "#F472B6";
        if (s.Contains("verde") && s.Contains("mil")) return "#365314";
        if (s.Contains("verde")) return "#16A34A";
        if (s.Contains("amar")) return "#EAB308";
        if (s.Contains("lar"))  return "#EA580C";
        if (s.Contains("rox"))  return "#7C3AED";
        if (s.Contains("lilas") || s.Contains("lilá")) return "#C4B5FD";
        if (s.Contains("beg") || s.Contains("cru")) return "#D4A574";
        if (s.Contains("mar"))  return "#92400E";
        return "#6B7280";
    }

    static string CorFg(string hex)
    {
        var dark = new HashSet<string> { "#111111","#1E3A5F","#1D4ED8","#7F1D1D",
                                         "#365314","#7C3AED","#92400E","#DC2626",
                                         "#EA580C","#16A34A","#1A1A1A","#808080" };
        return dark.Contains(hex) ? "#fff" : "#111";
    }

    static string NomeTipo(Models.TipoProduto t) => t switch
    {
        Models.TipoProduto.CamisaPolo  => "Camisa Polo",
        Models.TipoProduto.CamisaMalha => "Camiseta Malha",
        Models.TipoProduto.Jaleco      => "Jaleco",
        Models.TipoProduto.Calca       => "Calça",
        Models.TipoProduto.Bermuda     => "Bermuda",
        Models.TipoProduto.Agasalho    => "Agasalho",
        Models.TipoProduto.Colete      => "Colete",
        _ => t.ToString()
    };

    static string NomeLogomarca(Models.TipoLogomarca t) => t switch
    {
        Models.TipoLogomarca.Bordado    => "Bordado",
        Models.TipoLogomarca.SilkScreen => "Silk Screen",
        Models.TipoLogomarca.Sublimacao => "Sublimação",
        Models.TipoLogomarca.Transfer   => "Transfer",
        _ => t.ToString()
    };
}
