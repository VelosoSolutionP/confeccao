@page "/vitrine"
@attribute [Authorize]
@inject ApiService Api
@inject IJSRuntime JS

<PageTitle>Vitrine — Uniformes</PageTitle>

<div class="vit2-layout">

    <!-- ═══════════════ LEFT — Lista de fichas ═══════════════ -->
    <div class="vit2-left">
        <div class="vit2-left-header">
            <div class="vit2-left-title">
                <i class="bi bi-bag-heart-fill"></i> Fichas
            </div>
            <div class="vit2-filtros">
                <div class="vit2-search-wrap">
                    <i class="bi bi-search vit2-search-icon"></i>
                    <input class="vit2-search-input"
                           placeholder="Buscar modelo ou cliente..."
                           @bind="busca" @bind:event="oninput" />
                </div>
                <div class="vit2-custom-select">
                    <i class="bi bi-buildings vit2-sel-icon"></i>
                    <select @bind="filtroClienteId">
                        <option value="">Todos os clientes</option>
                        @foreach (var c in clientes)
                        {
                            var nome = string.IsNullOrEmpty(c.NomeFantasia) ? c.RazaoSocial : c.NomeFantasia;
                            <option value="@c.Id">@nome</option>
                        }
                    </select>
                    <i class="bi bi-chevron-down vit2-sel-arrow"></i>
                </div>
                <div class="vit2-custom-select">
                    <i class="bi bi-tag vit2-sel-icon"></i>
                    <select @bind="filtroTipo">
                        <option value="">Todos os tipos</option>
                        @foreach (var tp in Enum.GetValues<Models.TipoProduto>())
                        {
                            <option value="@((int)tp)">@NomeTipo(tp)</option>
                        }
                    </select>
                    <i class="bi bi-chevron-down vit2-sel-arrow"></i>
                </div>
            </div>
        </div>

        <div class="vit2-lista">
            @if (carregando)
            {
                @for (var i = 0; i < 6; i++)
                {
                    <div class="vit2-item-sk">
                        <div class="vit2-sk-line"></div>
                        <div class="vit2-sk-line short"></div>
                    </div>
                }
            }
            else if (!ProdutosFiltrados().Any())
            {
                <div class="vit2-lista-empty">
                    <i class="bi bi-bag-x"></i>
                    <p>Nenhuma ficha encontrada</p>
                    <a href="/layouts">Cadastrar fichas</a>
                </div>
            }
            else
            {
                @foreach (var p in ProdutosFiltrados())
                {
                    var pp = p;
                    var isAtivo = detalhe?.Id == pp.Id;
                    var isAprov = aprovados.Contains(pp.Id);
                    <div class="vit2-item @(isAtivo ? "ativo" : "") @(isAprov ? "aprovado" : "")"
                         @onclick="() => SelecionarFicha(pp)">
                        <div class="vit2-item-top">
                            <span class="vit2-tipo-badge">@NomeTipo(pp.TipoProduto)</span>
                            @if (isAprov) { <i class="bi bi-check-circle-fill vit2-badge-ok"></i> }
                        </div>
                        <div class="vit2-item-nome">@pp.Modelo</div>
                        <div class="vit2-item-cli">@pp.NomeCliente</div>
                        <div class="vit2-item-cores">
                            @foreach (var c in CoresDisponiveis(pp).Take(6))
                            {
                                <span class="vit2-mini-dot" style="background:@CorHex(c)" title="@c"></span>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- ═══════════════ RIGHT — Provador ═══════════════ -->
    <div class="vit2-provador">
        @if (detalhe is null)
        {
            <div class="vit2-empty">
                <i class="bi bi-bag-heart-fill"></i>
                <p>Selecione uma ficha ao lado<br>para experimentar no personagem</p>
            </div>
        }
        else
        {
            <div class="vit2-prov-inner">

                <!-- ── Cabeçalho ── -->
                <div class="vit2-prov-header">
                    <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap">
                        <span class="vit2-tipo-badge lg">@NomeTipo(detalhe.TipoProduto)</span>
                        <span class="vit2-prov-nome">@detalhe.Modelo</span>
                    </div>
                    <span class="vit2-prov-cli"><i class="bi bi-buildings"></i> @detalhe.NomeCliente</span>
                </div>

                <!-- ── Stage: personagem + ficha lateral ── -->
                <div class="vit2-stage">

                    <!-- Coluna do manequim -->
                    <div class="vit2-stage-main">
                        <div class="vit2-stage-top">
                            <div class="vit2-gen-toggle">
                                <button class="@(!feminino ? "ativo" : "")" @onclick="() => feminino = false" title="Masculino">
                                    <i class="bi bi-gender-male"></i>
                                </button>
                                <button class="@(feminino ? "ativo" : "")" @onclick="() => feminino = true" title="Feminino">
                                    <i class="bi bi-gender-female"></i>
                                </button>
                            </div>
                            <div class="vit2-sizes">
                                @foreach (var (tam, sc) in Tamanhos)
                                {
                                    var t = tam; var s = sc;
                                    <button class="vit2-size-btn @(tamanhoAtual == t ? "ativo" : "")"
                                            @onclick="() => { tamanhoAtual = t; tamScale = s; }">@t</button>
                                }
                            </div>
                        </div>

                        <div class="vit2-char-wrap"
                             style="transform:scale(@tamScale.ToString("F2", System.Globalization.CultureInfo.InvariantCulture));transform-origin:bottom center;transition:transform .25s">
                            <Personagem ShirtColor="@shirtHex"
                                        ShirtColor2="@shirt2Hex"
                                        PantsColor="@pantsHex"
                                        ShoesColor="@shoesHex"
                                        LogoColor="@logoHex"
                                        Feminino="@feminino"
                                        Angulo="@angulo"
                                        Tipo="@detalhe.TipoProduto" />
                        </div>

                        <!-- Botões de ângulo -->
                        <div class="vit2-angles">
                            <button class="vit2-angle-btn @(angulo==0?"ativo":"")" @onclick="()=>angulo=0" title="Frente">
                                <i class="bi bi-person-fill"></i> 0°
                            </button>
                            <button class="vit2-angle-btn @(angulo==45?"ativo":"")" @onclick="()=>angulo=45" title="45 graus">
                                45°
                            </button>
                            <button class="vit2-angle-btn @(angulo==90?"ativo":"")" @onclick="()=>angulo=90" title="Perfil">
                                <i class="bi bi-person-standing"></i> 90°
                            </button>
                            <button class="vit2-angle-btn @(angulo==180?"ativo":"")" @onclick="()=>angulo=180" title="Costas">
                                <i class="bi bi-person-fill" style="transform:scaleX(-1);display:inline-block"></i> 180°
                            </button>
                            <button class="vit2-angle-btn @(angulo==360?"ativo":"")" @onclick="()=>angulo=360" title="Rotação 360°">
                                <i class="bi bi-arrow-repeat @(angulo==360?"spin-icon":"")"></i> 360°
                            </button>
                        </div>

                        <div class="vit2-stage-label">@tamanhoAtual — @(feminino ? "Feminino" : "Masculino")</div>
                    </div>

                    <!-- Ficha técnica lateral -->
                    <div class="vit2-ficha-lat">
                        <div class="vit2-ficha-lat-title"><i class="bi bi-clipboard2-check-fill"></i> Ficha Técnica</div>

                        <!-- Tamanhos disponíveis -->
                        <div>
                            <div class="vit2-spec-label">Tamanhos disponíveis</div>
                            <div class="vit2-tam-row">
                                @foreach (var (tam, _) in Tamanhos)
                                {
                                    var t = tam;
                                    <span class="vit2-tam-chip @(tamanhoAtual==t?"ativo":"")"
                                          @onclick="() => { tamanhoAtual = t; tamScale = Tamanhos.First(x=>x.Tam==t).Scale; }"
                                          style="cursor:pointer">@t</span>
                                }
                            </div>
                        </div>

                        <!-- Tecido -->
                        <div class="vit2-spec">
                            <span>Tecido / Material</span>
                            <strong>@detalhe.Tecido</strong>
                        </div>

                        <!-- Logomarca -->
                        <div class="vit2-spec">
                            <span>Aplicação logomarca</span>
                            <strong>@NomeLogomarca(detalhe.TipoLogomarca)</strong>
                        </div>
                        @if (!string.IsNullOrEmpty(detalhe.PosicaoLogomarca))
                        {
                            <div class="vit2-spec">
                                <span>Posição</span>
                                <strong>@detalhe.PosicaoLogomarca</strong>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(detalhe.TamanhoLogomarca))
                        {
                            <div class="vit2-spec">
                                <span>Tamanho logo</span>
                                <strong>@detalhe.TamanhoLogomarca</strong>
                            </div>
                        }

                        <!-- Cuidados de lavagem -->
                        <div>
                            <div class="vit2-spec-label">Cuidados de lavagem</div>
                            <div class="vit2-cuidados">
                                @{ var cuidados = InfoCuidados(detalhe.Tecido); }
                                <div class="vit2-cuidado">
                                    <div class="vit2-care-icon vit2-care-circle">@cuidados.Lavagem</div>
                                    <span>@cuidados.LavagemLabel</span>
                                </div>
                                <div class="vit2-cuidado">
                                    <div class="vit2-care-icon">✗</div>
                                    <span>Sem alvejante</span>
                                </div>
                                <div class="vit2-cuidado">
                                    <div class="vit2-care-icon">@cuidados.Ferro</div>
                                    <span>Ferro @cuidados.FerroLabel</span>
                                </div>
                                <div class="vit2-cuidado @(!cuidados.SecadoraOk?"vit2-care-no":"")">
                                    <div class="vit2-care-icon">@(cuidados.SecadoraOk?"✓":"✗")</div>
                                    <span>Secadora</span>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(detalhe.Outros))
                        {
                            <div class="vit2-spec">
                                <span>Observações</span>
                                <span style="font-size:.78rem;color:var(--text-secondary)">@detalhe.Outros</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- ── Seletores de cor ── -->
                <div class="vit2-cores-panel">
                    <div class="vit2-cor-grupo">
                        <div class="vit2-cor-label">
                            @NomePeca(detalhe.TipoProduto)
                            <span class="vit2-cor-chip" style="background:@CorPrincipalHex;color:@CorFg(CorPrincipalHex)">
                                @corPrincipalNome
                            </span>
                        </div>
                        <div class="vit2-swatches">
                            @foreach (var cor in CoresDisponiveis(detalhe))
                            {
                                var c = cor; var hex = CorHex(c);
                                <button class="vit2-swatch @(corPrincipalNome == c ? "ativo" : "")"
                                        style="background:@hex" title="@c"
                                        @onclick="() => SetCorPrincipal(c)">
                                    @if (corPrincipalNome == c) { <i class="bi bi-check-lg" style="color:@CorFg(hex)"></i> }
                                </button>
                            }
                        </div>
                    </div>

                    @if (detalhe.TipoProduto == Models.TipoProduto.Agasalho)
                    {
                        <div class="vit2-cor-grupo">
                            <div class="vit2-cor-label">
                                Detalhe/Faixa
                                <span class="vit2-cor-chip" style="background:@shirt2Hex;color:@CorFg(shirt2Hex)">@shirt2Nome</span>
                            </div>
                            <div class="vit2-swatches">
                                @foreach (var cor in CoresCalca)
                                {
                                    var c = cor.Nome; var hex = cor.Hex;
                                    <button class="vit2-swatch @(shirt2Nome == c ? "ativo" : "")"
                                            style="background:@hex" title="@c"
                                            @onclick="() => { shirt2Nome = c; shirt2Hex = hex; }">
                                        @if (shirt2Nome == c) { <i class="bi bi-check-lg" style="color:@CorFg(hex)"></i> }
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    @if (MostraCalca)
                    {
                        <div class="vit2-cor-grupo">
                            <div class="vit2-cor-label">
                                Calça
                                <span class="vit2-cor-chip" style="background:@pantsHex;color:@CorFg(pantsHex)">@pantsNome</span>
                            </div>
                            <div class="vit2-swatches">
                                @foreach (var cor in CoresCalca)
                                {
                                    var c = cor.Nome; var hex = cor.Hex;
                                    <button class="vit2-swatch @(pantsNome == c ? "ativo" : "")"
                                            style="background:@hex" title="@c"
                                            @onclick="() => { pantsNome = c; pantsHex = hex; }">
                                        @if (pantsNome == c) { <i class="bi bi-check-lg" style="color:@CorFg(hex)"></i> }
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    <div class="vit2-cor-grupo">
                        <div class="vit2-cor-label">
                            Calçado
                            <span class="vit2-cor-chip" style="background:@shoesHex;color:@CorFg(shoesHex)">@shoesNome</span>
                        </div>
                        <div class="vit2-swatches">
                            @foreach (var cor in CoresSapato)
                            {
                                var c = cor.Nome; var hex = cor.Hex;
                                <button class="vit2-swatch @(shoesNome == c ? "ativo" : "")"
                                        style="background:@hex" title="@c"
                                        @onclick="() => { shoesNome = c; shoesHex = hex; }">
                                    @if (shoesNome == c) { <i class="bi bi-check-lg" style="color:@CorFg(hex)"></i> }
                                </button>
                            }
                        </div>
                    </div>
                </div>

                <!-- ── Ações ── -->
                <div class="vit2-acoes">
                    @if (aprovados.Contains(detalhe.Id))
                    {
                        <div class="vit2-aprovado-ok">
                            <i class="bi bi-check-circle-fill"></i> Ficha Aprovada!
                        </div>
                    }
                    else
                    {
                        <button class="btn-primary-modern vit2-btn-aprovar" @onclick="AprovarFicha">
                            <i class="bi bi-check-circle"></i> Aprovar Ficha
                        </button>
                    }
                    <button class="vit2-btn-print" @onclick="ImprimirProposta">
                        <i class="bi bi-printer-fill"></i> Imprimir
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<!-- PRINT -->
@if (detalhe is not null)
{
    <div class="proposta-print">
        <div class="proposta-header">
            <div class="proposta-logo"><i class="bi bi-scissors"></i> Roupa Solution</div>
            <div class="proposta-titulo">PROPOSTA DE UNIFORME</div>
            <div class="proposta-data">@DateTime.Now.ToString("dd/MM/yyyy")</div>
        </div>
        <div class="proposta-body">
            <div style="width:180px;height:270px">
                <Personagem ShirtColor="@shirtHex" ShirtColor2="@shirt2Hex"
                            PantsColor="@pantsHex" ShoesColor="@shoesHex"
                            LogoColor="@logoHex" Feminino="@feminino"
                            Angulo="0"
                            Tipo="@detalhe.TipoProduto" />
            </div>
            <div class="proposta-detalhes">
                <h2>@detalhe.Modelo</h2>
                <p><b>Cliente:</b> @detalhe.NomeCliente</p>
                <p><b>Tipo:</b> @NomeTipo(detalhe.TipoProduto)</p>
                <p><b>Tecido:</b> @detalhe.Tecido</p>
                <p><b>Cor da peça:</b> @corPrincipalNome</p>
                @if (MostraCalca) { <p><b>Calça:</b> @pantsNome</p> }
                <p><b>Calçado:</b> @shoesNome</p>
                <p><b>Logomarca:</b> @NomeLogomarca(detalhe.TipoLogomarca) — @detalhe.PosicaoLogomarca</p>
                <p><b>Tamanho:</b> @tamanhoAtual</p>
                @{ var c2 = InfoCuidados(detalhe.Tecido); }
                <p><b>Lavagem:</b> @c2.LavagemLabel</p>
                @if (!string.IsNullOrWhiteSpace(detalhe.Outros)) { <p><b>Obs:</b> @detalhe.Outros</p> }
            </div>
        </div>
        <div class="proposta-footer">Roupa Solution — Gestão Têxtil Profissional</div>
    </div>
}

@code {
    record CorOpc(string Nome, string Hex);

    static readonly CorOpc[] CoresCalca =
    [
        new("Azul Marinho", "#1E3A5F"), new("Preto", "#111111"),
        new("Cinza", "#6B7280"),        new("Cáqui", "#C5A55A"),
        new("Marrom", "#92400E"),       new("Branco", "#F5F5F5"),
    ];

    static readonly CorOpc[] CoresSapato =
    [
        new("Preto", "#1A1A1A"),    new("Marrom", "#7C4E28"),
        new("Branco", "#F0F0F0"),   new("Cinza", "#808080"),
        new("Caramelo", "#C87941"),
    ];

    static readonly (string Tam, double Scale)[] Tamanhos =
    [
        ("PP", 0.78), ("P", 0.87), ("M", 1.0), ("G", 1.10),
        ("GG", 1.18), ("EG", 1.25), ("EGG", 1.32)
    ];

    // ── Estado ──
    List<Models.LayoutDto>  produtos   = [];
    List<Models.ClienteDto> clientes   = [];
    Models.LayoutDto?       detalhe;
    HashSet<Guid>           aprovados  = [];
    bool  carregando = true;

    // Filtros
    string busca           = "";
    string filtroClienteId = "";
    string filtroTipo      = "";

    // Personagem
    bool   feminino     = false;
    int    angulo       = 0;
    string tamanhoAtual = "M";
    double tamScale     = 1.0;

    // Cores
    string corPrincipalNome = "";
    string shirtHex  = "#DC2626";
    string shirt2Nome = "Preto";       string shirt2Hex = "#111111";
    string pantsNome  = "Azul Marinho"; string pantsHex  = "#1E3A5F";
    string shoesNome  = "Preto";        string shoesHex  = "#1A1A1A";
    string logoHex    = "#FFFFFF";

    // ── Computed ──
    bool EhPecaBottom    => detalhe?.TipoProduto is Models.TipoProduto.Bermuda or Models.TipoProduto.Calca;
    bool MostraCalca     => detalhe is not null && !EhPecaBottom;
    string CorPrincipalHex => EhPecaBottom ? pantsHex : shirtHex;

    // ── Init ──
    protected override async Task OnInitializedAsync()
    {
        var t1 = Api.ListarLayoutsAsync();
        var t2 = Api.ListarClientesAsync();
        await Task.WhenAll(t1, t2);
        produtos   = t1.Result;
        clientes   = t2.Result;
        carregando = false;
        if (produtos.Any()) SelecionarFicha(produtos.First());
    }

    // ── Filtros ──
    IEnumerable<Models.LayoutDto> ProdutosFiltrados()
    {
        var q = produtos.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(busca))
            q = q.Where(p => p.Modelo.Contains(busca, StringComparison.OrdinalIgnoreCase)
                          || p.NomeCliente.Contains(busca, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrWhiteSpace(filtroClienteId) && Guid.TryParse(filtroClienteId, out var cid))
            q = q.Where(p => p.ClienteId == cid);
        if (!string.IsNullOrWhiteSpace(filtroTipo) && int.TryParse(filtroTipo, out var tp))
            q = q.Where(p => (int)p.TipoProduto == tp);
        return q;
    }

    // ── Seleção ──
    void SelecionarFicha(Models.LayoutDto p)
    {
        angulo       = 0;
        detalhe      = p;
        tamanhoAtual = "M";
        tamScale     = 1.0;
        var cores = CoresDisponiveis(p);
        corPrincipalNome = cores.FirstOrDefault() ?? "";
        SetCorPrincipal(corPrincipalNome);
        shirt2Nome = "Preto";        shirt2Hex = "#111111";
        pantsNome  = "Azul Marinho"; pantsHex  = "#1E3A5F";
        shoesNome  = "Preto";        shoesHex  = "#1A1A1A";
        logoHex    = "#FFFFFF";
    }

    // ── Aprovar ──
    void AprovarFicha()
    {
        if (detalhe is null) return;
        aprovados.Add(detalhe.Id);
    }

    async Task ImprimirProposta() => await JS.InvokeVoidAsync("window.print");

    // ── Cor principal ──
    void SetCorPrincipal(string cor)
    {
        corPrincipalNome = cor;
        var hex = CorHex(cor);
        if (EhPecaBottom) pantsHex = hex;
        else              shirtHex = hex;
    }

    // ── Cuidados de lavagem ──
    record InfoCuidado(string Lavagem, string LavagemLabel, string Ferro, string FerroLabel, bool SecadoraOk);

    static InfoCuidado InfoCuidados(string tecido)
    {
        var t = tecido.ToLower();
        if (t.Contains("linho") || t.Contains("seda") || t.Contains("viscose"))
            return new("✋", "Lavar à mão", "~", "suave", false);
        if (t.Contains("acrílico"))
            return new("✋", "Lavar à mão", "✗", "não usar", false);
        if (t.Contains("algodão") || t.Contains("cotton"))
            return new("30°", "Máquina 30°C", "✓", "150°C", false);
        return new("40°", "Máquina 40°C", "✓", "110°C", false);
    }

    // ── Helpers ──
    static List<string> CoresDisponiveis(Models.LayoutDto p) =>
        p.Cores.Split([" e ", " & ", ",", "/"], StringSplitOptions.RemoveEmptyEntries)
               .Select(c => c.Trim()).Where(c => !string.IsNullOrEmpty(c))
               .Distinct().ToList();

    static string CorHex(string c)
    {
        var s = c.ToLower();
        if (s.Contains("bran"))  return "#F5F5F5";
        if (s.Contains("pre"))   return "#111111";
        if (s.Contains("cza") || s.Contains("gray")) return "#9CA3AF";
        if (s.Contains("azul") && s.Contains("mar")) return "#1E3A5F";
        if (s.Contains("azul") && s.Contains("roy")) return "#1D4ED8";
        if (s.Contains("azul")) return "#3B82F6";
        if (s.Contains("verm")) return "#DC2626";
        if (s.Contains("bord") || s.Contains("vinh")) return "#7F1D1D";
        if (s.Contains("rosa")) return "#F472B6";
        if (s.Contains("verde") && s.Contains("mil")) return "#365314";
        if (s.Contains("verde")) return "#16A34A";
        if (s.Contains("amar")) return "#EAB308";
        if (s.Contains("lar"))  return "#EA580C";
        if (s.Contains("rox"))  return "#7C3AED";
        if (s.Contains("lilas") || s.Contains("lilá")) return "#C4B5FD";
        if (s.Contains("beg") || s.Contains("cru")) return "#D4A574";
        if (s.Contains("mar"))  return "#92400E";
        return "#6B7280";
    }

    static string CorFg(string hex)
    {
        var dark = new HashSet<string> { "#111111","#1E3A5F","#1D4ED8","#7F1D1D",
                                         "#365314","#7C3AED","#92400E","#DC2626",
                                         "#EA580C","#16A34A","#1A1A1A","#808080" };
        return dark.Contains(hex) ? "#fff" : "#111";
    }

    static string NomeTipo(Models.TipoProduto t) => t switch
    {
        Models.TipoProduto.CamisaPolo  => "Polo",
        Models.TipoProduto.CamisaMalha => "Malha",
        Models.TipoProduto.Jaleco      => "Jaleco",
        Models.TipoProduto.Calca       => "Calça",
        Models.TipoProduto.Bermuda     => "Bermuda",
        Models.TipoProduto.Agasalho    => "Agasalho",
        Models.TipoProduto.Colete      => "Colete",
        _ => t.ToString()
    };

    static string NomePeca(Models.TipoProduto t) => t switch
    {
        Models.TipoProduto.Bermuda     => "Cor da Bermuda",
        Models.TipoProduto.Calca       => "Cor da Calça",
        Models.TipoProduto.CamisaMalha => "Cor da Camiseta",
        Models.TipoProduto.Jaleco      => "Cor do Jaleco",
        Models.TipoProduto.Agasalho    => "Cor do Agasalho",
        Models.TipoProduto.Colete      => "Cor do Colete",
        _ => "Cor da Peça"
    };

    static string NomeLogomarca(Models.TipoLogomarca t) => t switch
    {
        Models.TipoLogomarca.Bordado    => "Bordado",
        Models.TipoLogomarca.SilkScreen => "Silk Screen",
        Models.TipoLogomarca.Sublimacao => "Sublimação",
        Models.TipoLogomarca.Transfer   => "Transfer",
        _ => t.ToString()
    };
}
