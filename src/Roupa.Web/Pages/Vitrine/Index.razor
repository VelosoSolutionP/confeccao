    record InfoCuidado(string Lavagem, string LavagemLabel, string Ferro, string FerroLabel, bool SecadoraOk);

    static InfoCuidado InfoCuidados(string tecido)
    {
        var t = tecido.ToLower();
        if (t.Contains("linho") || t.Contains("seda") || t.Contains("viscose"))
            return new("✋","Lavar à mão","~","Suave",false);
        if (t.Contains("acrílico"))
            return new("✋","Lavar à mão","✗","Não usar",false);
        if (t.Contains("algodão") || t.Contains("cotton"))
            return new("30°","Máquina 30°C","✓","Até 150°C",false);
        return new("40°","Máquina 40°C","✓","Até 110°C",false);
    }

    static List<PropTecido> PropriedadesTecido(string tecido)
    {
        var t = tecido.ToLower(); var r = new List<PropTecido>();
        if (t.Contains("algodão") || t.Contains("cotton")) r.Add(new("bi-wind","Respirável"));
        if (t.Contains("poliéster") || t.Contains("dry")) r.Add(new("bi-moisture","Dry-fit"));
        if (t.Contains("elastano") || t.Contains("lycra")) r.Add(new("bi-arrows-fullscreen","Elastano"));
        if (t.Contains("linho")) r.Add(new("bi-sun","Leveza"));
        if (t.Contains("malha")) r.Add(new("bi-grid-3x3","Malha"));
        if (r.Count == 0) r.Add(new("bi-patch-check","Alta durabilidade"));
        r.Add(new("bi-shield-check","Fio certificado"));
        return r;
    }

