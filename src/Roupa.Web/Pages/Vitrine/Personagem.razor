@* Personagem cartoon SVG com camadas de cor independentes *@
@* Frente e costas — usados pelo Vitrine para rotação 3D CSS *@

<div class="char-wrapper" style="--shirt:@ShirtColor;--pants:@PantsColor;--shoes:@ShoesColor;--logo:@LogoColor">
    <div class="char-card @(Spinning ? "spinning" : "")">

        <!-- ══ FRENTE ══ -->
        <div class="char-face front">
            <svg viewBox="0 0 220 500" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
                <!-- Sombra chão -->
                <ellipse cx="110" cy="492" rx="65" ry="8" fill="rgba(0,0,0,.12)"/>

                <!-- SAPATOS -->
                <rect x="57" y="428" width="42" height="20" rx="10" fill="var(--shoes)"/>
                <rect x="120" y="428" width="42" height="20" rx="10" fill="var(--shoes)"/>
                <rect x="60" y="418" width="37" height="18" rx="3" fill="var(--shoes)"/>
                <rect x="123" y="418" width="37" height="18" rx="3" fill="var(--shoes)"/>

                <!-- MEIAS (branco) -->
                <rect x="63" y="400" width="30" height="22" rx="2" fill="#e8e8e8"/>
                <rect x="126" y="400" width="30" height="22" rx="2" fill="#e8e8e8"/>

                <!-- CALÇAS -->
                <rect x="55" y="260" width="44" height="148" rx="6" fill="var(--pants)"/>
                <rect x="120" y="260" width="44" height="148" rx="6" fill="var(--pants)"/>
                <!-- Entreperna -->
                <rect x="55" y="260" width="109" height="34" rx="5" fill="var(--pants)"/>
                <!-- Cinto -->
                <rect x="50" y="252" width="119" height="14" rx="4" fill="rgba(0,0,0,.35)"/>
                <rect x="101" y="250" width="18" height="18" rx="3" fill="#B8960C"/>
                <rect x="107" y="256" width="6" height="6" rx="1" fill="#8B6914"/>

                <!-- CAMISA corpo -->
                <rect x="48" y="148" width="124" height="115" rx="6" fill="var(--shirt)"/>
                <!-- Sombra barra camisa -->
                <rect x="48" y="233" width="124" height="30" rx="0 0 6 6" fill="rgba(0,0,0,.07)"/>
                <!-- Manga esquerda -->
                <path d="M48 158 L14 218 L38 226 L62 172 Z" fill="var(--shirt)"/>
                <ellipse cx="24" cy="222" rx="14" ry="8" fill="var(--shirt)"/>
                <!-- Manga direita -->
                <path d="M172 158 L206 218 L182 226 L158 172 Z" fill="var(--shirt)"/>
                <ellipse cx="196" cy="222" rx="14" ry="8" fill="var(--shirt)"/>

                <!-- GOLA polo -->
                <path d="M82 148 L95 175 L110 175 L123 148 Q115 130 110 128 L110 148 L109 148 L101 128 Q95 130 82 148 Z"
                      fill="white" opacity=".92"/>
                <!-- Botões -->
                <circle cx="110" cy="150" r="3.5" fill="rgba(0,0,0,.2)"/>
                <circle cx="110" cy="162" r="3.5" fill="rgba(0,0,0,.2)"/>
                <line x1="82" y1="148" x2="123" y2="148" stroke="rgba(0,0,0,.15)" stroke-width="1"/>

                <!-- LOGO bordado no peito -->
                <rect x="56" y="168" width="40" height="30" rx="4" fill="rgba(255,255,255,.18)" stroke="var(--logo)" stroke-width="1.5"/>
                <text x="76" y="187" text-anchor="middle" font-size="7" fill="var(--logo)" font-family="Arial,sans-serif" font-weight="bold">LOGO</text>

                <!-- PESCOÇO -->
                <rect x="95" y="112" width="30" height="22" rx="6" fill="#F5C5A0"/>

                <!-- CABEÇA -->
                <circle cx="110" cy="78" r="52" fill="#F5C5A0"/>

                <!-- CABELO -->
                <path d="M58 72 Q62 20 110 17 Q158 20 162 72 Q152 40 110 38 Q68 40 58 72 Z" fill="#3D2B1A"/>
                <ellipse cx="110" cy="34" rx="48" ry="20" fill="#3D2B1A"/>

                <!-- ORELHAS -->
                <ellipse cx="58" cy="82" rx="9" ry="13" fill="#F5C5A0"/>
                <ellipse cx="162" cy="82" rx="9" ry="13" fill="#F5C5A0"/>

                <!-- OLHOS (brancos) -->
                <ellipse cx="91" cy="76" rx="11" ry="12" fill="white"/>
                <ellipse cx="129" cy="76" rx="11" ry="12" fill="white"/>
                <!-- Íris -->
                <circle cx="93" cy="77" r="7" fill="#2A1A08"/>
                <circle cx="131" cy="77" r="7" fill="#2A1A08"/>
                <!-- Brilho -->
                <circle cx="90" cy="74" r="2.5" fill="white"/>
                <circle cx="128" cy="74" r="2.5" fill="white"/>

                <!-- SOBRANCELHAS -->
                <path d="M80 62 Q91 57 102 62" stroke="#3D2B1A" stroke-width="3" fill="none" stroke-linecap="round"/>
                <path d="M118 62 Q129 57 140 62" stroke="#3D2B1A" stroke-width="3" fill="none" stroke-linecap="round"/>

                <!-- NARIZ -->
                <path d="M106 90 Q110 97 114 90" stroke="#D4956A" stroke-width="2.5" fill="none" stroke-linecap="round"/>

                <!-- SORRISO -->
                <path d="M91 102 Q110 118 129 102" stroke="#C0704A" stroke-width="2.5" fill="none" stroke-linecap="round"/>
                <path d="M91 102 Q110 120 129 102" fill="rgba(200,100,80,.25)"/>
            </svg>
        </div>

        <!-- ══ COSTAS ══ -->
        <div class="char-face back">
            <svg viewBox="0 0 220 500" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
                <!-- Sombra -->
                <ellipse cx="110" cy="492" rx="65" ry="8" fill="rgba(0,0,0,.12)"/>

                <!-- SAPATOS (costas) -->
                <rect x="57" y="428" width="42" height="20" rx="10" fill="var(--shoes)"/>
                <rect x="120" y="428" width="42" height="20" rx="10" fill="var(--shoes)"/>
                <rect x="60" y="418" width="37" height="18" rx="3" fill="var(--shoes)"/>
                <rect x="123" y="418" width="37" height="18" rx="3" fill="var(--shoes)"/>

                <!-- MEIAS -->
                <rect x="63" y="400" width="30" height="22" rx="2" fill="#e8e8e8"/>
                <rect x="126" y="400" width="30" height="22" rx="2" fill="#e8e8e8"/>

                <!-- CALÇAS (costas) -->
                <rect x="55" y="260" width="44" height="148" rx="6" fill="var(--pants)"/>
                <rect x="120" y="260" width="44" height="148" rx="6" fill="var(--pants)"/>
                <rect x="55" y="260" width="109" height="34" rx="5" fill="var(--pants)"/>
                <rect x="50" y="252" width="119" height="14" rx="4" fill="rgba(0,0,0,.35)"/>

                <!-- CAMISA costas -->
                <rect x="48" y="135" width="124" height="128" rx="6" fill="var(--shirt)"/>
                <rect x="48" y="233" width="124" height="30" rx="0 0 6 6" fill="rgba(0,0,0,.07)"/>
                <!-- Manga esquerda (costas) -->
                <path d="M48 145 L14 205 L38 213 L62 158 Z" fill="var(--shirt)"/>
                <ellipse cx="24" cy="209" rx="14" ry="8" fill="var(--shirt)"/>
                <!-- Manga direita (costas) -->
                <path d="M172 145 L206 205 L182 213 L158 158 Z" fill="var(--shirt)"/>
                <ellipse cx="196" cy="209" rx="14" ry="8" fill="var(--shirt)"/>

                <!-- Gola costas -->
                <path d="M84 135 Q110 125 136 135" stroke="white" stroke-width="10" fill="none" stroke-linecap="round"/>

                <!-- Costura central costas -->
                <line x1="110" y1="135" x2="110" y2="263" stroke="rgba(0,0,0,.1)" stroke-width="1.5" stroke-dasharray="4,4"/>

                <!-- PESCOÇO costas -->
                <rect x="95" y="112" width="30" height="26" rx="6" fill="#F5C5A0"/>

                <!-- CABEÇA (costas = cabelo cobrindo tudo) -->
                <circle cx="110" cy="78" r="52" fill="#3D2B1A"/>
                <circle cx="110" cy="78" r="44" fill="#3D2B1A"/>
                <!-- Um pouco de pele embaixo -->
                <ellipse cx="110" cy="118" rx="28" ry="10" fill="#F5C5A0"/>

                <!-- ORELHAS -->
                <ellipse cx="58" cy="82" rx="9" ry="13" fill="#F5C5A0"/>
                <ellipse cx="162" cy="82" rx="9" ry="13" fill="#F5C5A0"/>
            </svg>
        </div>

    </div>

    <!-- Indicador de vista -->
    <div class="char-label">
        @if (Spinning)
        {
            <i class="bi bi-arrow-repeat spin-icon"></i> <span>Girando 360°</span>
        }
        else
        {
            <span>@ViewLabel</span>
        }
    </div>
</div>

@code {
    [Parameter] public string ShirtColor { get; set; } = "#DC2626";
    [Parameter] public string PantsColor { get; set; } = "#1E3A5F";
    [Parameter] public string ShoesColor { get; set; } = "#2D2D2D";
    [Parameter] public string LogoColor  { get; set; } = "#FFFFFF";
    [Parameter] public bool   Spinning   { get; set; } = false;
    [Parameter] public string ViewLabel  { get; set; } = "Frente";
}
