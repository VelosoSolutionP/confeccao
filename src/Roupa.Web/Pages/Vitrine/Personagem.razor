@* Personagem cartoon SVG — frente, perfil, costas, spin *@
<div class="char-wrap" style="transform-origin:bottom center">
    <div class="char-card @GetCardClass()">

        @if (Angulo == 90)
        {
            <!-- ══ PERFIL (90°) ══ -->
            <div class="char-face front">
                <svg viewBox="0 0 240 520" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
                    <ellipse cx="118" cy="511" rx="50" ry="8" fill="rgba(0,0,0,.13)"/>
                    <!-- Sapatos perfil -->
                    <path d="M90 443 Q84 458 122 460 L145 459 Q151 459 151 452 L151 442 Q151 436 144 435 L106 435 Q94 435 90 443Z" fill="@ShoesColor"/>
                    <rect x="98" y="428" width="40" height="14" rx="4" fill="@ShoesColor"/>
                    <rect x="100" y="408" width="34" height="24" rx="3" fill="#EFEFEF"/>
                    <!-- Pernas perfil -->
                    @if (IsBermuda)
                    {
                        <rect x="96" y="265" width="44" height="115" rx="8" fill="@PantsColor"/>
                        <rect x="102" y="370" width="30" height="44" rx="5" fill="@SkinColor"/>
                        <rect x="93" y="260" width="50" height="12" rx="5" fill="rgba(0,0,0,.18)"/>
                    }
                    else
                    {
                        <rect x="96" y="265" width="44" height="165" rx="8" fill="@PantsColor"/>
                        <rect x="93" y="258" width="50" height="14" rx="5" fill="rgba(0,0,0,.28)"/>
                        <rect x="114" y="256" width="16" height="16" rx="3" fill="#B8960C"/>
                    }
                    <!-- Corpo perfil -->
                    @if (IsColete)
                    {
                        <rect x="92" y="148" width="52" height="120" rx="6" fill="@ShirtColor"/>
                        <rect x="142" y="152" width="24" height="80" rx="10" fill="@SkinColor"/>
                        <ellipse cx="154" cy="240" rx="13" ry="10" fill="@SkinColor"/>
                    }
                    else if (IsAgasalho)
                    {
                        <rect x="90" y="148" width="52" height="120" rx="6" fill="@ShirtColor"/>
                        <rect x="140" y="152" width="26" height="88" rx="10" fill="@ShirtColor"/>
                        <rect x="155" y="233" width="20" height="13" rx="5" fill="@ShirtColor2"/>
                        <ellipse cx="153" cy="252" rx="13" ry="10" fill="@SkinColor"/>
                    }
                    else if (IsJaleco)
                    {
                        <rect x="88" y="148" width="55" height="155" rx="6" fill="@ShirtColor"/>
                        <rect x="140" y="152" width="26" height="92" rx="10" fill="@ShirtColor"/>
                        <ellipse cx="153" cy="252" rx="13" ry="10" fill="@SkinColor"/>
                    }
                    else
                    {
                        <rect x="90" y="148" width="52" height="120" rx="6" fill="@ShirtColor"/>
                        <rect x="140" y="152" width="26" height="88" rx="10" fill="@ShirtColor"/>
                        <ellipse cx="153" cy="248" rx="13" ry="10" fill="@SkinColor"/>
                    }
                    <!-- Pescoço -->
                    <rect x="106" y="117" width="24" height="24" rx="5" fill="@SkinColor"/>
                    <!-- Cabeça perfil (face p/ direita) -->
                    <ellipse cx="122" cy="74" rx="43" ry="46" fill="@SkinColor"/>
                    <path d="M79 68 Q85 16 122 14 Q158 16 162 55 Q154 22 122 20 Q92 22 87 68 Z" fill="#3D2B1A"/>
                    <ellipse cx="122" cy="20" rx="42" ry="14" fill="#3D2B1A"/>
                    @if (Feminino) { <path d="M79 68 Q72 108 76 138 Q80 108 88 98 Z" fill="#3D2B1A"/> }
                    <!-- Orelha esquerda -->
                    <ellipse cx="80" cy="78" rx="7" ry="11" fill="@SkinColor"/>
                    <!-- Olho direito -->
                    @if (Feminino)
                    {
                        <ellipse cx="148" cy="74" rx="9" ry="11" fill="white"/>
                        <circle cx="150" cy="75" r="6" fill="#1A0D05"/>
                        <circle cx="148" cy="72" r="2.5" fill="white"/>
                        <path d="M139 64 Q148 60 158 64" stroke="#1A0D05" stroke-width="2.5" fill="none" stroke-linecap="round"/>
                        <ellipse cx="135" cy="87" rx="6" ry="4" fill="rgba(220,100,100,.15)"/>
                    }
                    else
                    {
                        <ellipse cx="147" cy="76" rx="9" ry="10" fill="white"/>
                        <circle cx="149" cy="77" r="6" fill="#1A0D05"/>
                        <circle cx="147" cy="74" r="2.5" fill="white"/>
                        <path d="M138 65 Q147 61 158 65" stroke="#3D2B1A" stroke-width="3" fill="none" stroke-linecap="round"/>
                    }
                    <!-- Nariz perfil -->
                    <path d="M163 84 Q174 94 171 107" stroke="#C8806A" stroke-width="2.5" fill="none" stroke-linecap="round"/>
                    <!-- Boca perfil -->
                    <path d="M158 108 Q166 113 164 120" stroke="#C06050" stroke-width="2" fill="none" stroke-linecap="round"/>
                </svg>
            </div>
        }
        else if (Angulo == 180 && !Girando)
        {
            <!-- ══ COSTAS estático (180°) ══ -->
            <div class="char-face front">
                @BackSvg
            </div>
        }
        else
        {
            <!-- ══ FRENTE (0°, 45°, spin) ══ -->
            <div class="char-face front">
                @FrontSvg
            </div>
            @if (Girando)
            {
                <div class="char-face back">
                    @BackSvg
                </div>
            }
        }

    </div>
    <div class="char-label">
        @if (Girando) { <i class="bi bi-arrow-repeat spin-icon"></i><span> 360°</span> }
        else { <span>@AnguloLabel</span> }
    </div>
</div>

@code {
    [Parameter] public string ShirtColor  { get; set; } = "#DC2626";
    [Parameter] public string ShirtColor2 { get; set; } = "#991B1B";
    [Parameter] public string PantsColor  { get; set; } = "#1E3A5F";
    [Parameter] public string ShoesColor  { get; set; } = "#2D2D2D";
    [Parameter] public string LogoColor   { get; set; } = "#FFFFFF";
    [Parameter] public string SkinColor   { get; set; } = "#F5C5A0";
    [Parameter] public bool   Feminino    { get; set; } = false;
    [Parameter] public int    Angulo      { get; set; } = 0;
    [Parameter] public Models.TipoProduto Tipo { get; set; } = Models.TipoProduto.CamisaPolo;

    bool Girando     => Angulo >= 360;
    bool IsBermuda   => Tipo == Models.TipoProduto.Bermuda;
    bool IsCalca     => Tipo == Models.TipoProduto.Calca;
    bool IsJaleco    => Tipo == Models.TipoProduto.Jaleco;
    bool IsColete    => Tipo == Models.TipoProduto.Colete;
    bool IsAgasalho  => Tipo == Models.TipoProduto.Agasalho;
    bool IsCamisaMalha => Tipo == Models.TipoProduto.CamisaMalha;

    string AnguloLabel => Angulo switch
    {
        45  => "45°",
        90  => "Perfil",
        180 => "Costas",
        _   => "Frente"
    };

    string GetCardClass()
    {
        if (Girando)  return "spinning";
        if (Angulo == 45) return "angle-45";
        return "";
    }

