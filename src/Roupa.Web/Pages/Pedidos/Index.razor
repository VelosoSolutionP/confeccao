@page "/pedidos"
@attribute [Authorize]
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Pedidos</PageTitle>

<div class="page-header">
    <div>
        <div class="page-title">Pedidos</div>
        <div class="page-subtitle">Gerencie todos os pedidos de uniformes</div>
    </div>
    <button class="btn-primary-modern" @onclick="AbrirDrawer">
        <i class="bi bi-plus-lg"></i> Novo Pedido
    </button>
</div>

@if (mostrarDrawer)
{
    <div class="drawer-overlay" @onclick="FecharDrawer"></div>
    <div class="drawer">
        <div class="drawer-header">
            <span class="drawer-title">Novo Pedido</span>
            <button class="drawer-close" @onclick="FecharDrawer"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="drawer-body form-modern">
            @if (!string.IsNullOrEmpty(erroForm))
            {
                <div class="form-error-banner">
                    <i class="bi bi-exclamation-circle-fill"></i> @erroForm
                </div>
            }

            <div class="form-group">
                <label>Cliente *</label>
                <select class="input-field" @bind="novoPedido.ClienteId"
                        style="appearance:auto">
                    <option value="">Selecione o cliente...</option>
                    @foreach (var c in clientes)
                    {
                        <option value="@c.Id">@c.NomeFantasia</option>
                    }
                </select>
                @if (camposInvalidos.Contains("cliente"))
                {
                    <span class="campo-erro">Selecione um cliente</span>
                }
            </div>

            <div class="form-group">
                <label>Data de Entrega</label>
                <input class="input-field" type="date" @bind="novoPedido.DataEntrega" />
            </div>

            <div class="form-group">
                <label>Observações</label>
                <textarea class="input-field" rows="3" @bind="novoPedido.Observacoes"
                          placeholder="Informações adicionais sobre o pedido..."
                          style="resize:vertical"></textarea>
            </div>
        </div>
        <div class="drawer-footer">
            <button class="btn-ghost" @onclick="FecharDrawer">Cancelar</button>
            <button class="btn-primary-modern" @onclick="CriarPedido" disabled="@salvando">
                @if (salvando) { <span class="spinner-border spinner-border-sm"></span> }
                else { <i class="bi bi-check-lg"></i> }
                Criar Pedido
            </button>
        </div>
    </div>
}

<!-- FILTROS -->
@if (!carregando && pedidos.Any())
{
    <div style="display:flex;gap:.5rem;margin-bottom:1.25rem;flex-wrap:wrap">
        @foreach (var f in filtros)
        {
            <button class="@(filtroAtivo == f.Key ? "btn-primary-modern" : "btn-ghost")"
                    style="font-size:.8rem;padding:.35rem .85rem"
                    @onclick="() => filtroAtivo = f.Key">
                @f.Value
            </button>
        }
    </div>
}

@if (carregando)
{
    <div class="loading-center"><div class="spinner-border text-primary"></div></div>
}
else if (!PedidosFiltrados.Any())
{
    <div class="card-modern">
        <div class="empty-state">
            <i class="bi bi-bag"></i>
            <p>@(pedidos.Any() ? "Nenhum pedido nesse status." : "Nenhum pedido cadastrado ainda.")</p>
            @if (!pedidos.Any())
            {
                <button class="btn-primary-modern mt-3" @onclick="AbrirDrawer">
                    <i class="bi bi-plus-lg"></i> Criar primeiro pedido
                </button>
            }
        </div>
    </div>
}
else
{
    <div class="card-modern">
        <div class="card-header-modern">
            <span class="card-title">
                <i class="bi bi-bag-check text-primary"></i>
                @PedidosFiltrados.Count pedido@(PedidosFiltrados.Count != 1 ? "s" : "")
            </span>
        </div>
        <div class="table-responsive">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Cliente</th>
                        <th>Status</th>
                        <th>Entrega</th>
                        <th>Total</th>
                        <th>Criado</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in PedidosFiltrados)
                    {
                        <tr>
                            <td class="fw-medium" style="font-family:monospace">@p.Numero</td>
                            <td>@p.NomeCliente</td>
                            <td><span class="badge-modern @BadgeCls(p.Status)">@p.StatusNome</span></td>
                            <td>@(p.DataEntrega?.ToString("dd/MM/yy") ?? "—")</td>
                            <td style="font-weight:600">@p.Total.ToString("C2")</td>
                            <td style="color:var(--surface-400);font-size:.8rem">@p.CriadoEm.ToString("dd/MM/yy")</td>
                            <td>
                                <button class="btn-table primary"
                                        @onclick="@(() => Nav.NavigateTo($"/pedidos/{p.Id}"))">
                                    <i class="bi bi-eye"></i> Abrir
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery] public string? ClienteId { get; set; }

    private List<Models.PedidoDto>  pedidos   = [];
    private List<Models.ClienteDto> clientes  = [];
    private Models.CriarPedidoModel novoPedido = new();
    private HashSet<string> camposInvalidos = [];
    private bool carregando = true, mostrarDrawer, salvando;
    private string erroForm = "", filtroAtivo = "todos";

    private static Dictionary<string, string> filtros = new()
    {
        ["todos"]    = "Todos",
        ["abertos"]  = "Abertos",
        ["producao"] = "Em Produção",
        ["concluido"]= "Concluídos",
        ["cancelado"]= "Cancelados",
    };

    private List<Models.PedidoDto> PedidosFiltrados => filtroAtivo switch
    {
        "abertos"  => pedidos.Where(p => p.Status is Models.StatusPedido.Rascunho or Models.StatusPedido.Confirmado).ToList(),
        "producao" => pedidos.Where(p => p.Status == Models.StatusPedido.EmProducao).ToList(),
        "concluido"=> pedidos.Where(p => p.Status == Models.StatusPedido.Concluido).ToList(),
        "cancelado"=> pedidos.Where(p => p.Status == Models.StatusPedido.Cancelado).ToList(),
        _          => pedidos
    };

    protected override async Task OnInitializedAsync()
    {
        clientes = await Api.ListarClientesAsync();
        pedidos  = await Api.ListarPedidosAsync();
        if (Guid.TryParse(ClienteId, out var cId))
        {
            pedidos = pedidos.Where(p => p.ClienteId == cId).ToList();
            novoPedido.ClienteId = cId;
        }
        carregando = false;
    }

    private void AbrirDrawer() { mostrarDrawer = true; erroForm = ""; camposInvalidos.Clear(); novoPedido = new(); }
    private void FecharDrawer() { mostrarDrawer = false; erroForm = ""; camposInvalidos.Clear(); }

    private async Task CriarPedido()
    {
        camposInvalidos.Clear();
        if (novoPedido.ClienteId == Guid.Empty || novoPedido.ClienteId == default)
            camposInvalidos.Add("cliente");
        if (camposInvalidos.Any()) return;

        salvando = true;
        erroForm = "";
        var (sucesso, dados, erro) = await Api.CriarPedidoAsync(novoPedido);
        if (sucesso && dados is not null)
        {
            FecharDrawer();
            Nav.NavigateTo($"/pedidos/{dados.Id}");
        }
        else erroForm = erro ?? "Erro ao criar pedido.";
        salvando = false;
    }

    private static string BadgeCls(Models.StatusPedido s) => s switch
    {
        Models.StatusPedido.Rascunho   => "draft",
        Models.StatusPedido.Confirmado => "info",
        Models.StatusPedido.EmProducao => "warning",
        Models.StatusPedido.Concluido  => "success",
        Models.StatusPedido.Cancelado  => "danger",
        _ => "draft"
    };
}
