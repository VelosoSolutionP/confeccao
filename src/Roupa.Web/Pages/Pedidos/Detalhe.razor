@page "/pedidos/{Id:guid}"
@attribute [Authorize]
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Pedido @pedido?.Numero</PageTitle>

@if (carregando)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (pedido is null)
{
    <div class="alert alert-danger">Pedido não encontrado.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <button class="btn btn-sm btn-outline-secondary mb-2" @onclick="Voltar">← Voltar</button>
            <h2>@pedido.Numero</h2>
            <p class="text-muted mb-0">@pedido.NomeCliente · Criado em @pedido.CriadoEm.ToString("dd/MM/yyyy")</p>
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <span class="badge fs-6 @BadgeStatus(pedido.Status)">@pedido.StatusNome</span>
            @if (pedido.Status == Models.StatusPedido.Rascunho)
            {
                <button class="btn btn-primary" @onclick="Confirmar">Confirmar</button>
                <button class="btn btn-outline-danger" @onclick="CancelarPedido">Cancelar</button>
            }
            @if (pedido.Status == Models.StatusPedido.Confirmado)
            {
                <button class="btn btn-warning" @onclick="IniciarProducao">Iniciar Produção</button>
                <button class="btn btn-outline-danger" @onclick="CancelarPedido">Cancelar</button>
            }
            @if (pedido.Status == Models.StatusPedido.EmProducao)
            {
                <button class="btn btn-success" @onclick="Concluir">Concluir</button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(erroStatus))
    {
        <div class="alert alert-danger">@erroStatus</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold d-flex justify-content-between">
                    <span>Itens do Pedido</span>
                    @if (pedido.Status == Models.StatusPedido.Rascunho)
                    {
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => mostrarItemForm = !mostrarItemForm">+ Item</button>
                    }
                </div>
                @if (mostrarItemForm)
                {
                    <div class="card-body border-bottom">
                        @if (!string.IsNullOrEmpty(erroItem))
                        {
                            <div class="alert alert-danger py-2">@erroItem</div>
                        }
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="form-label">Layout *</label>
                                <select class="form-select form-select-sm" @bind="novoItem.LayoutId">
                                    <option value="">Selecione...</option>
                                    @foreach (var l in layouts)
                                    {
                                        <option value="@l.Id">@l.Modelo</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Tamanho *</label>
                                <select class="form-select form-select-sm" @bind="novoItem.Tamanho">
                                    @foreach (var t in new[] { "PP", "P", "M", "G", "GG", "EG", "EGG" })
                                    {
                                        <option>@t</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Qtd *</label>
                                <input class="form-control form-control-sm" type="number" min="1" @bind="novoItem.Quantidade" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Preço Unit. *</label>
                                <input class="form-control form-control-sm" type="number" step="0.01" @bind="novoItem.PrecoUnitario" />
                            </div>
                            <div class="col-md-1 d-flex align-items-end">
                                <button class="btn btn-sm btn-success w-100" @onclick="AdicionarItem" disabled="@salvandoItem">OK</button>
                            </div>
                        </div>
                    </div>
                }
                <div class="card-body p-0">
                    @if (!pedido.Itens.Any())
                    {
                        <div class="text-center py-4 text-muted">Nenhum item adicionado.</div>
                    }
                    else
                    {
                        <table class="table mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Layout</th>
                                    <th>Tamanho</th>
                                    <th>Qtd</th>
                                    <th>Preço Unit.</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var i in pedido.Itens)
                                {
                                    <tr>
                                        <td>@i.ModeloLayout</td>
                                        <td><span class="badge bg-light text-dark">@i.Tamanho</span></td>
                                        <td>@i.Quantidade</td>
                                        <td>@i.PrecoUnitario.ToString("C2")</td>
                                        <td class="fw-semibold">@i.Total.ToString("C2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-light">
                                    <td colspan="4" class="text-end fw-bold">Total Geral:</td>
                                    <td class="fw-bold fs-5">@pedido.Total.ToString("C2")</td>
                                </tr>
                            </tfoot>
                        </table>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">Informações</div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item"><strong>Cliente:</strong> @pedido.NomeCliente</li>
                    <li class="list-group-item"><strong>Status:</strong> @pedido.StatusNome</li>
                    <li class="list-group-item"><strong>Entrega:</strong> @(pedido.DataEntrega?.ToString("dd/MM/yyyy") ?? "Não definida")</li>
                    @if (!string.IsNullOrEmpty(pedido.Observacoes))
                    {
                        <li class="list-group-item"><strong>Obs:</strong> @pedido.Observacoes</li>
                    }
                    <li class="list-group-item"><strong>Criado:</strong> @pedido.CriadoEm.ToString("dd/MM/yyyy HH:mm")</li>
                </ul>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Models.PedidoDto? pedido;
    private List<Models.LayoutDto> layouts = [];
    private Models.AdicionarItemModel novoItem = new();
    private bool carregando = true, mostrarItemForm, salvandoItem;
    private string erroStatus = "", erroItem = "";

    protected override async Task OnInitializedAsync()
    {
        pedido = await Api.ObterPedidoAsync(Id);
        if (pedido is not null)
            layouts = await Api.ListarLayoutsPorClienteAsync(pedido.ClienteId);
        carregando = false;
    }

    private void Voltar() => Nav.NavigateTo("/pedidos");
    private Task Confirmar() => AlterarStatus("confirmar");
    private Task CancelarPedido() => AlterarStatus("cancelar");
    private Task IniciarProducao() => AlterarStatus("producao");
    private Task Concluir() => AlterarStatus("concluir");

    private async Task AlterarStatus(string acao)
    {
        erroStatus = "";
        var (sucesso, erro) = await Api.AlterarStatusPedidoAsync(Id, acao);
        if (sucesso) pedido = await Api.ObterPedidoAsync(Id);
        else erroStatus = erro ?? "Erro.";
    }

    private async Task AdicionarItem()
    {
        salvandoItem = true;
        erroItem = "";
        var (sucesso, erro) = await Api.AdicionarItemAsync(Id, novoItem);
        if (sucesso)
        {
            pedido = await Api.ObterPedidoAsync(Id);
            novoItem = new();
            mostrarItemForm = false;
        }
        else erroItem = erro ?? "Erro.";
        salvandoItem = false;
    }

    private static string BadgeStatus(Models.StatusPedido s) => s switch
    {
        Models.StatusPedido.Rascunho   => "bg-secondary",
        Models.StatusPedido.Confirmado => "bg-primary",
        Models.StatusPedido.EmProducao => "bg-warning text-dark",
        Models.StatusPedido.Concluido  => "bg-success",
        Models.StatusPedido.Cancelado  => "bg-danger",
        _ => "bg-secondary"
    };
}
