@page "/login"
@layout LoginLayout
@inject ApiService Api
@inject ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="login-page">
    <div class="login-left">
        <div class="login-brand">
            <div class="brand-icon">
                <i class="bi bi-scissors"></i>
            </div>
            <h1>Roupa Solution</h1>
            <p>Gestão inteligente de uniformes corporativos</p>
        </div>
        <div class="login-features">
            <div class="feature-item">
                <i class="bi bi-people-fill"></i>
                <span>Gestão de clientes e layouts</span>
            </div>
            <div class="feature-item">
                <i class="bi bi-clipboard2-check-fill"></i>
                <span>Controle de pedidos em tempo real</span>
            </div>
            <div class="feature-item">
                <i class="bi bi-graph-up-arrow"></i>
                <span>Acompanhamento da produção</span>
            </div>
        </div>
    </div>

    <div class="login-right">
        <div class="login-card">
            <div class="login-card-header">
                <h2>Bem-vindo de volta</h2>
                <p>Faça login para acessar o sistema</p>
            </div>

            <EditForm Model="model" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                @if (!string.IsNullOrEmpty(erro))
                {
                    <div class="login-error">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        @erro
                    </div>
                }

                <div class="form-field">
                    <label>E-mail</label>
                    <div class="input-wrapper">
                        <i class="bi bi-envelope input-icon"></i>
                        <input class="form-input" type="email" @bind="model.Email" placeholder="seu@email.com" />
                    </div>
                </div>

                <div class="form-field">
                    <label>Senha</label>
                    <div class="input-wrapper">
                        <i class="bi bi-lock input-icon"></i>
                        <input class="form-input" type="@(mostrarSenha ? "text" : "password")"
                               @bind="model.Senha" placeholder="••••••••" />
                        <button type="button" class="eye-btn" @onclick="ToggleSenha" tabindex="-1">
                            <i class="bi @(mostrarSenha ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                </div>

                <button class="btn-login" type="submit" disabled="@carregando">
                    @if (carregando)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Entrando...</span>
                    }
                    else
                    {
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        <span>Entrar</span>
                    }
                </button>
            </EditForm>
        </div>

        <!-- DOWNLOAD APK -->
        <div class="login-apk">
            <a href="/downloads/roupa-solution.apk" download class="login-apk-btn">
                <i class="bi bi-android2"></i>
                <div>
                    <span class="login-apk-label">Baixar para Android</span>
                    <span class="login-apk-sub">Instale o app no celular</span>
                </div>
            </a>
        </div>
    </div>
</div>

@code {
    private Models.LoginModel model = new();
    private string erro = "";
    private bool carregando;
    private bool mostrarSenha;

    private void ToggleSenha() => mostrarSenha = !mostrarSenha;

    private async Task HandleLogin()
    {
        carregando = true;
        erro = "";
        var (sucesso, token, erroMsg) = await Api.LoginAsync(model);
        if (sucesso && token is not null)
        {
            await LocalStorage.SetItemAsStringAsync("authToken", token.AccessToken);
            ((AppAuthStateProvider)AuthStateProvider).NotificarLogin(token.AccessToken);
            Nav.NavigateTo("/");
        }
        else
        {
            erro = erroMsg ?? "Email ou senha inválidos.";
        }
        carregando = false;
    }
}
