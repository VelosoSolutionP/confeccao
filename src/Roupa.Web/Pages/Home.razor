@page "/"
@attribute [Authorize]
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Dashboard</PageTitle>

<div class="page-header">
    <div>
        <div class="page-title">Dashboard</div>
        <div class="page-subtitle">Visão geral em tempo real</div>
    </div>
    <button class="btn-primary-modern" @onclick='() => Nav.NavigateTo("/pedidos")'>
        <i class="bi bi-plus-lg"></i> Novo Pedido
    </button>
</div>

@if (carregando)
{
    <div class="loading-center"><div class="spinner-border text-primary"></div></div>
}
else
{
    <!-- STAT CARDS -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-xl-3">
            <div class="stat-card blue" style="cursor:pointer" @onclick='() => Nav.NavigateTo("/clientes")'>
                <div class="stat-icon"><i class="bi bi-buildings"></i></div>
                <div class="stat-value">@totalClientes</div>
                <div class="stat-label">Clientes ativos</div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="stat-card green" style="cursor:pointer" @onclick='() => Nav.NavigateTo("/layouts")'>
                <div class="stat-icon"><i class="bi bi-palette2"></i></div>
                <div class="stat-value">@totalLayouts</div>
                <div class="stat-label">Fichas de layout</div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="stat-card yellow" style="cursor:pointer" @onclick='() => Nav.NavigateTo("/pedidos")'>
                <div class="stat-icon"><i class="bi bi-bag-check"></i></div>
                <div class="stat-value">@pedidosAbertos</div>
                <div class="stat-label">Pedidos abertos</div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="stat-card cyan">
                <div class="stat-icon"><i class="bi bi-gear-wide-connected"></i></div>
                <div class="stat-value">@pedidosProducao</div>
                <div class="stat-label">Em produção</div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- FRAME: STATUS PIPELINE -->
        <div class="col-12 col-xl-5">
            <div class="card-modern h-100">
                <div class="card-header-modern">
                    <span class="card-title">
                        <i class="bi bi-kanban text-primary"></i> Pipeline de Pedidos
                    </span>
                </div>
                <div class="card-body-modern">
                    @{
                        var grupos = new[]
                        {
                            ("Rascunho",    Models.StatusPedido.Rascunho,    "draft",   "bi-pencil"),
                            ("Confirmado",  Models.StatusPedido.Confirmado,  "info",    "bi-check-circle"),
                            ("Em Produção", Models.StatusPedido.EmProducao,  "warning", "bi-gear"),
                            ("Concluído",   Models.StatusPedido.Concluido,   "success", "bi-bag-check"),
                            ("Cancelado",   Models.StatusPedido.Cancelado,   "danger",  "bi-x-circle"),
                        };
                    }
                    <div style="display:flex;flex-direction:column;gap:.6rem">
                        @foreach (var (nome, status, cls, icon) in grupos)
                        {
                            var qtd = todoPedidos.Count(p => p.Status == status);
                            <div style="display:flex;align-items:center;gap:.75rem">
                                <span class="badge-modern @cls" style="width:120px;justify-content:center">
                                    <i class="bi @icon"></i> @nome
                                </span>
                                <div style="flex:1;height:8px;background:var(--surface-100);border-radius:99px;overflow:hidden">
                                    <div style="height:100%;width:@(todoPedidos.Count > 0 ? (qtd * 100 / todoPedidos.Count) : 0)%;background:var(--brand-500);border-radius:99px;transition:width .4s ease"></div>
                                </div>
                                <span style="font-size:.8rem;font-weight:700;color:var(--surface-700);width:20px;text-align:right">@qtd</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- FRAME: ÚLTIMOS PEDIDOS -->
        <div class="col-12 col-xl-7">
            <div class="card-modern">
                <div class="card-header-modern">
                    <span class="card-title">
                        <i class="bi bi-clock-history text-primary"></i> Últimos Pedidos
                    </span>
                    <a href="/pedidos" class="btn-ghost" style="font-size:.78rem;padding:.3rem .75rem">
                        Ver todos <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                @if (!ultimosPedidos.Any())
                {
                    <div class="empty-state" style="padding:2rem">
                        <i class="bi bi-bag" style="font-size:2rem"></i>
                        <p>Nenhum pedido ainda.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table-modern">
                            <thead>
                                <tr>
                                    <th>Número</th>
                                    <th>Cliente</th>
                                    <th>Status</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in ultimosPedidos)
                                {
                                    <tr style="cursor:pointer" @onclick="@(() => Nav.NavigateTo($"/pedidos/{p.Id}"))">
                                        <td class="fw-medium">@p.Numero</td>
                                        <td>@p.NomeCliente</td>
                                        <td><span class="badge-modern @BadgeCls(p.Status)">@p.StatusNome</span></td>
                                        <td style="font-weight:600">@p.Total.ToString("C2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool carregando = true;
    private int totalClientes, totalLayouts, pedidosAbertos, pedidosProducao;
    private List<Models.PedidoDto> todoPedidos = [];
    private List<Models.PedidoDto> ultimosPedidos = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var clientes = await Api.ListarClientesAsync();
            var layouts  = await Api.ListarLayoutsAsync();
            todoPedidos  = await Api.ListarPedidosAsync();

            totalClientes   = clientes.Count;
            totalLayouts    = layouts.Count;
            pedidosAbertos  = todoPedidos.Count(p => p.Status is Models.StatusPedido.Rascunho or Models.StatusPedido.Confirmado);
            pedidosProducao = todoPedidos.Count(p => p.Status == Models.StatusPedido.EmProducao);
            ultimosPedidos  = todoPedidos.Take(6).ToList();
        }
        catch { }
        carregando = false;
    }

    private static string BadgeCls(Models.StatusPedido s) => s switch
    {
        Models.StatusPedido.Rascunho   => "draft",
        Models.StatusPedido.Confirmado => "info",
        Models.StatusPedido.EmProducao => "warning",
        Models.StatusPedido.Concluido  => "success",
        Models.StatusPedido.Cancelado  => "danger",
        _ => "draft"
    };
}
